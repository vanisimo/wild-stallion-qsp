---

! ================================================
! FILE: modules/actions/tavern/girl_work_rules.qsps
! Форма
! ================================================

#GirlWorkRulesUniformMenu
    *clr
    clr
    cla

    gs 'GirlWorkRulesNormalizeKey', $ARGS[0]
    $GirlRuleGirl = $GirlRuleKey
    $GirlRuleReturnLoc = $ARGS[1]

    if $GirlRuleReturnLoc = '':
        $GirlRuleReturnLoc = 'TavernMain'
    end

    gs 'GirlWorkRulesEnsureName', $GirlRuleGirl

    if LOC('ShowGirlSidebar') = 1:
        gs 'ShowGirlSidebar', $GirlRuleGirl
    end

    *pl '══════════════════════════════════════════════'
    *pl ' РАБОЧАЯ ФОРМА: ' + UCASE($RealName[$GirlRuleGirl])
    *pl '══════════════════════════════════════════════'
    *pl ' '

    gs 'GirlWorkRulesPrintText', 'uniform_thoughts'

    *pl ' '

    gs 'GirlWorkRulesBuildUniformMenu'

    *p 'Какую форму назначить <a href="exec:gs ''Menu.Show'', ''GirlWorkRulesUniformMenuBox''">для работы</a>?'
---

#GirlWorkRulesBuildUniformMenu
    gs 'Menu.Destroy', 'GirlWorkRulesUniformMenuBox'
    gs 'Menu.Create', 'GirlWorkRulesUniformMenuBox'

    gs 'Menu.Add', 'GirlWorkRulesUniformMenuBox', 'Обычная форма', ''
    gs 'Menu.AddModule', 'GirlWorkRulesUniformMenuBox', {
        gt 'GirlWorkRulesSetUniform', $GirlRuleGirl, 0, $GirlRuleReturnLoc
    }

    if uniform_purchased[$GirlRuleGirl] = 1 or revealing_uniform_all_bought = 1:
        gs 'Menu.Add', 'GirlWorkRulesUniformMenuBox', 'Откровенная форма', ''
        gs 'Menu.AddModule', 'GirlWorkRulesUniformMenuBox', {
            gt 'GirlWorkRulesSetUniform', $GirlRuleGirl, 1, $GirlRuleReturnLoc
        }
    else:
        gs 'Menu.Add', 'GirlWorkRulesUniformMenuBox', 'Откровенная форма недоступна', ''
        gs 'Menu.AddModule', 'GirlWorkRulesUniformMenuBox', {
            gt 'GirlWorkRulesUniformBlocked', $GirlRuleGirl, $GirlRuleReturnLoc
        }
    end

    gs 'Menu.Add', 'GirlWorkRulesUniformMenuBox', 'Назад', ''
    gs 'Menu.AddModule', 'GirlWorkRulesUniformMenuBox', {
        gt 'GirlWorkRulesMenu', $GirlRuleGirl, $GirlRuleReturnLoc
    }
---

#GirlWorkRulesSetUniform
    *clr
    clr
    cla

    gs 'GirlWorkRulesNormalizeKey', $ARGS[0]
    $GirlRuleGirl = $GirlRuleKey
    GirlRuleUniformNew = ARGS[1]
    $GirlRuleReturnLoc = $ARGS[2]

    if GirlRuleUniformNew < 0:
        GirlRuleUniformNew = 0
    end

    if GirlRuleUniformNew > 1:
        GirlRuleUniformNew = 1
    end

    if GirlRuleUniformNew = 1:
        if uniform_purchased[$GirlRuleGirl] = 0 and revealing_uniform_all_bought = 0:
            gt 'GirlWorkRulesUniformBlocked', $GirlRuleGirl, $GirlRuleReturnLoc
        end
    end

    GirlUniformLevel[$GirlRuleGirl] = GirlRuleUniformNew

    gs 'GirlWorkRulesEnsureName', $GirlRuleGirl

    if LOC('ShowGirlSidebar') = 1:
        gs 'ShowGirlSidebar', $GirlRuleGirl
    end

    *pl '══════════════════════════════════════════════'
    *pl ' ФОРМА ОБНОВЛЕНА'
    *pl '══════════════════════════════════════════════'
    *pl ' '

    gs 'GirlWorkRulesPrintText', 'uniform_set'

    *pl ' '

    act 'Вернуться к правилам':
        gt 'GirlWorkRulesMenu', $GirlRuleGirl, $GirlRuleReturnLoc
    end

    killvar 'GirlRuleUniformNew'
---

#GirlWorkRulesUniformBlocked
    *clr
    clr
    cla

    gs 'GirlWorkRulesNormalizeKey', $ARGS[0]
    $GirlRuleGirl = $GirlRuleKey
    $GirlRuleReturnLoc = $ARGS[1]

    if $GirlRuleReturnLoc = '':
        $GirlRuleReturnLoc = 'TavernMain'
    end

    gs 'GirlWorkRulesEnsureName', $GirlRuleGirl

    *pl '══════════════════════════════════════════════'
    *pl ' ФОРМА НЕДОСТУПНА'
    *pl '══════════════════════════════════════════════'
    *pl ' '

    gs 'GirlWorkRulesPrintText', 'uniform_blocked'

    *pl ' '

    act 'Вернуться':
        gt 'GirlWorkRulesUniformMenu', $GirlRuleGirl, $GirlRuleReturnLoc
    end
---

#GirlWorkRulesNormalizeKey
    if LOC('NormalizeGirlKey') = 1:
        gs 'NormalizeGirlKey', $ARGS[0]
        $GirlRuleKey = $GirlKey
    else:
        $GirlRuleKey = LCASE($ARGS[0])
    end
---

#GirlWorkRulesEnsureName
    gs 'GirlWorkRulesNormalizeKey', $ARGS[0]
    $GirlRuleNameKey = $GirlRuleKey

    if $RealName[$GirlRuleNameKey] = '':
        if $GirlRuleNameKey = 'amanda':
            $RealName[$GirlRuleNameKey] = 'Аманда'
        elseif $GirlRuleNameKey = 'melissa':
            $RealName[$GirlRuleNameKey] = 'Мелисса'
        elseif $GirlRuleNameKey = 'sandra':
            $RealName[$GirlRuleNameKey] = 'Сандра'
        else:
            $RealName[$GirlRuleNameKey] = $GirlRuleNameKey
        end
    end

    killvar '$GirlRuleNameKey'
---
