#AmandaHomeFirstSexResolveContext
    $AmandaFirstSexContext = 'pure'

    if AmandaLegareFirstSexDone = 1:
        if PlayerKnows_AmandaLegareFridayRace = 1:
            $AmandaFirstSexContext = 'legare_known'
        else
            $AmandaFirstSexContext = 'legare_hidden'
        end
    end
---

#AmandaHomeFirstSexMenuLabel
    $AmandaFirstSexMenuLabel = 'Первая близость'

    if AmandaHomeStage = 6:
        $AmandaFirstSexMenuLabel = 'Поговорить перед первым разом'
    elseif AmandaHomeStage = 7:
        $AmandaFirstSexMenuLabel = 'Первая ночь'
    elseif AmandaHomeStage = 8:
        $AmandaFirstSexMenuLabel = 'Вечер вместе'
    elseif AmandaHomeStage = 9:
        $AmandaFirstSexMenuLabel = 'Попробовать иначе'
    elseif AmandaHomeStage = 10:
        $AmandaFirstSexMenuLabel = 'Последний шаг перед свободой'
    end
---

#AmandaHomeFirstSexTalkText
    gs 'AmandaHomeFirstSexResolveContext'

    if $AmandaFirstSexContext = 'legare_known':
        if virginity['amanda'] = 1:
            $AmandaHomeText = 'Аманда сидит на кровати, кутается в простыню и долго молчит — пальцы теребят край ткани, пока костяшки не белеют. Потом поднимает на вас взгляд: влажный, испуганный, упрямый.'
            $AmandaHomeText += '<br><br>«Ты видел подворотню… Я знаю, что ты знаешь.» Голос дрожит. «С Легаре было… грязно и быстро. Рот — не то. Руки — не то. То, о чём мы говорим сейчас… внутри… я ещё никому не отдавала. Никому.»'
            $AmandaHomeText += '<br><br>Она сглатывает: «Если войдёшь в меня — это будет впервые. По-настоящему. Не как в подворотне. Не как стыдная ошибка. С тобой. И мне… страшно. И я всё равно хочу.»'
        else
            $AmandaHomeText = 'Аманда сидит на кровати, кутается в простыню и долго молчит. Потом выдыхает: «Ты видел подворотню… Я знаю. Но с Легаре было… не то. Не то, о чём я мечтала, когда думала о ком-то своём.»'
            $AmandaHomeText += '<br><br>Она поднимает взгляд: «Со Стефаном… если снова войдёшь в меня — это уже будет по-другому. Честнее. Ты всё ещё хочешь?»'
        end
    elseif $AmandaFirstSexContext = 'legare_hidden':
        if virginity['amanda'] = 1:
            $AmandaHomeText = 'Аманда смотрит на дверь — за стенкой шаги Мелиссы, потом тишина. Она обнимает колени, ночнушка сползла с плеча, но она этого не замечает.'
            $AmandaHomeText += '<br><br>«Тише… мама внизу,» — шепчет она. «Мы уже зашли так далеко… руками, ртом, твоим языком. Я… я даже не знала, что тело может так.»'
            $AmandaHomeText += '<br><br>Голос срывается: «Но если ты войдёшь в меня — я перестану быть девочкой, которой мама гордилась. Не отмотаешь. И я… я боюсь. Не тебя. Себя. Что захочу ещё.»'
            $AmandaHomeText += '<br><br>Она не говорит о Легаре. Может, ты и не знаешь, о чём молчать — пока.'
        else
            $AmandaHomeText = 'Аманда смотрит на дверь — за стенкой шаги Мелиссы, потом тишина. «Тише… мама внизу,» — шепчет она и краснеет.'
            $AmandaHomeText += '<br><br>«Мы уже зашли далеко — руками, ртом, твоим языком. Но если ты снова войдёшь в меня… это всё равно каждый раз как первый шаг дальше от «просто семья».»'
            $AmandaHomeText += '<br><br>Она не говорит о Легаре. Может, ты и не знаешь, о чём молчать — пока.'
        end
    else
        if virginity['amanda'] = 1:
            $AmandaHomeText = 'Аманда смотрит на вас с влажными глазами — без бравады, без привычной дерзости. Только вы, свеча и её дыхание, сбившееся от страха и ожидания.'
            $AmandaHomeText += '<br><br>«Стефан… мы уже делали многое. Ты трогал меня. Я трогала тебя. Ты… твой язык…» — она не может договорить, краснеет. «Но внутри я ещё никого не пускала. Никого. И если ты войдёшь… это будет мой первый раз. Настоящий. С братом, с которым я росла. С тем, кому я…»'
            $AmandaHomeText += '<br><br>Она обрывает себя, прижимает ладонь к груди: «Тише… за стенкой Мелисса. Мама внизу. Если стонем — нас услышат. И я всё равно… я хочу. Боюсь. И хочу.»'
        else
            $AmandaHomeText = 'Аманда смотрит на вас с влажными глазами: «Стефан… мы уже делали многое. Но каждый раз — как будто снова решаюсь сорваться с цепи, которую сама на себя надела.»'
            $AmandaHomeText += '<br><br>«Тише… за стенкой Мелисса. И мама внизу. Если стонем громко — нас услышат.»'
        end
    end

    if virginity['amanda'] = 1:
        $AmandaHomeText += '<br><br>Она касается вашей щеки — ненадолго, почти стыдливо: «Ты… точно хочешь этого? Со мной? Не потому что я удобная. Не потому что я сестра под боком. А потому что… я — это я?»'
    else
        $AmandaHomeText += '<br><br>Она кусает губу: «Ты… точно хочешь этого? Со мной?»'
    end
---

#AmandaHomeFirstSexTalkChoiceText
    $AmandaFirstSexTalkChoice = LCASE($ARGS[0])

    if $AmandaFirstSexTalkChoice = 'gentle':
        if virginity['amanda'] = 1:
            $AmandaHomeText = 'Вы говорите спокойно: не торопитесь, остановитесь в любой момент, если станет страшно — и это нормально. Аманда замирает, потом выдыхает так, будто держала дыхание всю неделю.'
            $AmandaHomeText += '<br><br>Она прижимается лбом к вашему плечу, голос едва слышен: «Тогда… не сегодня, если я заплачу. Или сегодня, если не заплачу, дурак.» Пауза. «Спасибо, что не смеёшься надо мной.»'
        else
            $AmandaHomeText = 'Вы говорите спокойно: не торопитесь, остановитесь, если станет страшно. Аманда выдыхает и прижимается лбом к вашему плечу.'
            $AmandaHomeText += '<br><br>«Ладно… тогда завтра. Или сегодня, если не передумаю, дурак,» — шепчет она почти без вызова.'
        end
    else
        if virginity['amanda'] = 1:
            $AmandaHomeText = 'Вы фыркаете мягко: она сама дошла до куни, а теперь строит из себя святую. Аманда вспыхивает — и вдруг смеётся тихо, нервно, по-настоящему.'
            $AmandaHomeText += '<br><br>«Ну и кто тут распустился…» — бросает она, но глаза блестят. «Ладно. Только тише. И если вдруг… если мне станет страшно — не обижайся, если скажу стоп.»'
            $AmandaHomeText += '<br><br>Она кивает сама себе: «Хотя кого я обманываю. Я уже давно не остановилась.»'
        else
            $AmandaHomeText = 'Вы фыркаете: она сама дошла до куни, а теперь строит из себя святую. Аманда вспыхивает, но не отстраняется.'
            $AmandaHomeText += '<br><br>«Ну и кто тут распустился…» — бросает она. «Ладно. Только тише. И не смотри так, будто я уже твоя.»'
        end
    end

    killvar '$AmandaFirstSexTalkChoice'
---

