    if $AmandaFirstSexContext = 'legare_known':
        $AmandaHomeText = 'Ритм нарастает. Аманда вздрагивает, выгибается — и внезапно замирает, сжимая вас внутри. «Ах… Стефан… это… не как с…» — обрывает себя и стонет в подушку.'
        $AmandaHomeText += '<br><br>«Почему я раньше не… боже… так приятно…» — шепчет она, дрожа. «Тише… умоляю…»'
    elseif $AmandaFirstSexContext = 'legare_hidden':
        $AmandaHomeText = 'Аманда внезапно выгибается и замирает — киска судорожно сжимает ваш ствол. Она стонет в подушку, потом шепчет смущённо и счастливо:'
        $AmandaHomeText += '<br><br>«Я… я не знала, что так… Почему я раньше не…» — и тут же кусает губу: «Тише, дурак…»'
    else
        $AmandaHomeText = 'Аманда вскрикивает в подушку, всё тело выгибается — она кончает на вашем члене, и мокрая киска судорожно жмёт ствол.'
        $AmandaHomeText += '<br><br>«Почему я раньше не… так приятно…» — выдыхает она, красная и смущённая. «Тише… не разнеси кровать…»'
    end

