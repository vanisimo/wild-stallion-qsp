    end

    if ClarissaVaginalSexCount < 5:
        exit
    end

    gs 'PlayerCheckAnalExperience'

    if PlayerHadAnalExperience = 0:
        exit
    end

    if time < 3:
        exit
    end

    ClarissaAnalCanStart = 1
---

#ClarissaAnalSceneStart
    gs 'ClarissaAnalCanStart'

    if ClarissaAnalCanStart = 0:
        gt 'WineShop'
    end

    gs 'CanCumToday'

    if Result = 0 and debug = 0:
        *p 'Сегодня вы слишком устали для такого шага.'
        gs 'ActUiPrepare', 'Вернуться', 'return'
        act $ActUiLabel, $ActUiIconPath:
            gt 'WineShop'
        end
        exit
    end

    gs 'ClarissaAnalSceneText'

    *clr
    clr
    cla

    *pl '══════════════════════════════════════════════'
    *pl ' КЛАРИССА — АНАЛ'
    *pl '══════════════════════════════════════════════'
    *pl ' '
    *p $ClarissaIntimText
    *pl ' '

    analvirgin['clarissa'] = 0
    ClarissaAnalDone = 1
    sluttiness['clarissa'] += 2
    otkroven['clarissa'] += 2

    gs 'RegisterSex', 'clarissa', 'anal', 1, 1
    gs 'RegisterPlayerCum'
    gs 'ClampGirlSocialStats', 'clarissa'

    gs 'ActUiPrepare', 'Вернуться в лавку', 'return'
    act $ActUiLabel, $ActUiIconPath:
        gt 'WineShop'
    end
---

#ClarissaLegareReconcileCanStart
    ClarissaLegareReconcileCanStart = 0

