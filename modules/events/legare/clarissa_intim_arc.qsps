#PlayerCheckAnalExperience
    PlayerHadAnalExperience = 0

    if hadanal['becky'] = 1 or hadanal['sandra'] = 1 or hadanal['amanda'] = 1:
        PlayerHadAnalExperience = 1
        exit
    end

    if hadanal['melissa'] = 1 or hadanal['inga'] = 1 or hadanal['clarissa'] = 1:
        PlayerHadAnalExperience = 1
        exit
    end

    if analacts['becky'] >= 1 or analacts['sandra'] >= 1 or analacts['amanda'] >= 1:
        PlayerHadAnalExperience = 1
    end
---

#ClarissaIntimUnlockTry
    if ClarissaIntimUnlocked = 1:
        exit
    end

    if Friends['clarissa'] < 10:
        exit
    end

    if AmandaLegareFirstSexDone = 1 or Fact_AmandaLegareFridayAlley = 1:
        if ClarissaJealousy >= 2 or ClarissaPrivateTalkReady = 1 or ClarissaRouteHint = 1:
            ClarissaIntimUnlocked = 1
            $ClarissaIntimUnlockReason = 'jealousy'
            exit
        end
    end

    if MelissaHomeSex = 1 and PlayerKnows_MelissaClarissaBrotherGossip = 1:
        if Friends['clarissa'] >= 10:
            ClarissaIntimUnlocked = 1
            $ClarissaIntimUnlockReason = 'melissa'
            exit
        end
    end

    if ClarissaBulkWinePurchases >= 2 and Friends['clarissa'] >= 12:
        ClarissaIntimUnlocked = 1
        $ClarissaIntimUnlockReason = 'wine'
    end
---

#ClarissaWineBulkPurchase
    ClarissaWineBulkUnits = $ARGS[0]

    if ClarissaWineBulkUnits < 60:
        exit
    end

    ClarissaBulkWinePurchases += 1
    Friends['clarissa'] += 2
    ClarissaTrustStefan += 1

    gs 'ClampGirlSocialStats', 'clarissa'
    gs 'ClarissaIntimUnlockTry'
---

#ClarissaIntimCanAdvance
    ClarissaIntimCanAdvance = 0

    if ClarissaIntimUnlocked = 0:
        exit
    end

    if ClarissaIntimSex = 1:
        exit
    end

    if ClarissaIntimStepToday = 1:
        exit
    end

    if time < 2 or time > 4:
        exit
    end

    if ClarissaIntimStage >= 3:
        exit
    end

    if Friends['clarissa'] < 12 + ClarissaIntimStage:
        exit
    end

    ClarissaIntimCanAdvance = 1
---

#ClarissaIntimStep
    gs 'ClarissaIntimCanAdvance'

    if ClarissaIntimCanAdvance = 0:
        gt 'WineShop'
    end

    if ClarissaIntimStage = 0:
        $ClarissaIntimStepKey = 'kiss'
    elseif ClarissaIntimStage = 1:
        $ClarissaIntimStepKey = 'petting'
    elseif ClarissaIntimStage = 2:
        $ClarissaIntimStepKey = 'blowjob'
    else:
        gt 'WineShop'
    end

    gs 'ClarissaIntimStepText', $ClarissaIntimStepKey

    *clr
    clr
    cla

    *pl '══════════════════════════════════════════════'
    *pl ' ЛАВКА ЛЕГАРЕ — БЛИЗОСТЬ'
    *pl '══════════════════════════════════════════════'
    *pl ' '
    *p $ClarissaIntimText
    *pl ' '

    ClarissaIntimStage += 1
    ClarissaIntimStepToday = 1
    ClarissaPlayerPath += 1

    if $ClarissaIntimStepKey = 'kiss':
        KissCount['clarissa'] += 1
        love['clarissa'] += 1
        otkroven['clarissa'] += 1
    elseif $ClarissaIntimStepKey = 'petting':
        CaressCount['clarissa'] += 1
        otkroven['clarissa'] += 1
    elseif $ClarissaIntimStepKey = 'blowjob':
        BlowjobCount['clarissa'] += 1
        OralCount['clarissa'] += 1
        sluttiness['clarissa'] += 1
    end

    gs 'ClampGirlSocialStats', 'clarissa'
    killvar '$ClarissaIntimStepKey'

    gs 'ActUiPrepare', 'Вернуться в лавку', 'return'
    act $ActUiLabel, $ActUiIconPath:
        gt 'WineShop'
    end
---

#ClarissaIntimFirstSexLaunch
    if ClarissaIntimUnlocked = 0 or ClarissaIntimStage < 3:
        gt 'WineShop'
    end

    if ClarissaIntimSex = 1:
        gt 'WineShop'
    end

    gs 'ClarissaIntimStepText', 'presex'

    *clr
    clr
    cla

    *pl '══════════════════════════════════════════════'
    *pl ' ПЕРВАЯ БЛИЗОСТЬ'
    *pl '══════════════════════════════════════════════'
    *pl ' '
    *p $ClarissaIntimText
    *pl ' '

    ClarissaIntimFirstSexActive = 1
    ClarissaIntimStepToday = 1

    if IntimStage['clarissa'] < 4:
        IntimStage['clarissa'] = 4
    end

    if otkroven['clarissa'] < 22:
        otkroven['clarissa'] = 22
    end

    gt 'SexSceneStart', 'clarissa', 'ClarissaIntimAfterSex', 'clarissa_first'
---

#ClarissaIntimAfterSex
    gs 'ClarissaIntimAfterSexText'

    *clr
    clr
    cla

    *pl '══════════════════════════════════════════════'
    *pl ' ПОСЛЕ'
    *pl '══════════════════════════════════════════════'
    *pl ' '
