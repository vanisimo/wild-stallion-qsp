    end

    gs 'ActUiPrepare', 'Остаться в лавке', 'return'
    act $ActUiLabel, $ActUiIconPath:
        gt 'WineShop'
    end
---

#ClarissaShopTalk
    $ClarissaTalkReturnLoc = $ARGS[0]

    if $ClarissaTalkReturnLoc = '':
        $ClarissaTalkReturnLoc = 'WineShop'
    end

    if LOC($ClarissaTalkReturnLoc) = 0:
        $ClarissaTalkReturnLoc = 'WineShop'
    end

    *clr
    clr
    cla

    gs 'InitClarissa'
    gs 'ClarissaIntimUnlockTry'

    *pl '══════════════════════════════════════════════'
    *pl ' РАЗГОВОР С КЛАРИССОЙ'
    *pl '══════════════════════════════════════════════'
    *pl ' '

    gs 'ClarissaShopTalkIntroText'

    *p $ClarissaTalkText
    *pl ' '

    Friends['clarissa'] += 1

    if ClarissaIntimUnlocked = 0:
        gs 'ClarissaIntimUnlockTry'
    end

    gs 'ActUiPrepare', 'Вернуться', 'return'
    act $ActUiLabel, $ActUiIconPath:
        gt $ClarissaTalkReturnLoc
    end
---

#ClarissaAnalCanStart
    ClarissaAnalCanStart = 0

    if ClarissaIntimSex = 0:
        exit
    end

    if ClarissaAnalDone = 1:
        exit
    end

    if analvirgin['clarissa'] = 0:
