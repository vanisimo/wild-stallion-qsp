        else:
            $ClarissaTalkText = 'Кларисса рассказывает о винных сортах и о том, как тяжело держать лавку, когда муж то в зале, то в чужих разговорах.'
        end
    else:
        $ClarissaTalkText = 'Кларисса улыбается чуть иначе, чем покупателям. "Снова по делу — или снова за мной?"'
