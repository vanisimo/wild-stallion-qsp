#ClarissaIntimStepText
    $ClarissaIntimStepKey = LCASE($ARGS[0])

    if $ClarissaIntimStepKey = 'kiss':
        $ClarissaIntimText = 'Кларисса целует вас у бочонков — быстро, почти зло. "Не думай, что я слепая," — шепчет она. "Но и я не монахиня."'
    elseif $ClarissaIntimStepKey = 'petting':
        $ClarissaIntimText = 'Она притягивает вас в подсобку, где пахнет дубом и вином. Ласки уверенные — у неё больше опыта, чем у девчонок из трактира.'
    elseif $ClarissaIntimStepKey = 'blowjob':
        $ClarissaIntimText = 'Кларисса опускается на колени между ящиками. "Тихо," — шепчет она. — "Альбер в зале, а дети его старшего брака сегодня у соседей… надеюсь."'
    elseif $ClarissaIntimStepKey = 'presex':
        $ClarissaIntimText = 'Она смотрит на вас прямо: "Если мы это сделаем — это уже не торговля и не ревность. Я выбираю себя. Хотя бы на сегодня."'
    else:
        $ClarissaIntimText = 'Между бочонками повисает тёплая тишина.'
    end

    killvar '$ClarissaIntimStepKey'
