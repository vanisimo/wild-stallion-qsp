            $HallLewdText = 'Ну вот и приехали. Уже не просто пьяный хрен облапал работницу, а сама работница держит зал на крючке. Трактир и так имеет репутацию приличного заведения, а такие сцены могут её разрушить. Можно пресечь — поставить точку, пока слухи не разнесли трактир по косточкам. Можно наблюдать: не лезть, посмотреть, как далеко она сама зайдёт. А можно поощрить ради чаевых. Деньги-то звенят красиво... только потом не надо удивляться, что "Дикий Жеребец" начнут искать не по вывеске, а по сплетням.'
        elseif TavernReputation <= 30:
            $HallLewdText = 'Ну вот и приехали. Уже не просто пьяный хрен облапал работницу, а сама работница держит зал на крючке. Трактир и так имеет репутацию не самого приличного заведения, а такие сцены могут её окончательно разрушить. Можно пресечь — поставить точку, пока слухи не разнесли трактир по косточкам. Можно наблюдать: не лезть, посмотреть, как далеко она сама зайдёт. А можно поощрить ради чаевых. Деньги-то звенят красиво... только потом не надо удивляться, что "Дикий Жеребец" начнут искать не по вывеске, а по сплетням.'
        else:
            $HallLewdText = 'Ну вот и приехали. Уже не просто пьяный хрен облапал работницу, а сама работница держит зал на крючке. Можно пресечь — поставить точку, пока слухи не разнесли трактир по косточкам. Можно наблюдать: не лезть, посмотреть, как далеко она сама зайдёт. А можно поощрить ради чаевых. Деньги-то звенят красиво... только потом не надо удивляться, что "Дикий Жеребец" начнут искать не по вывеске, а по сплетням.'
        end

    elseif $HallLewdTextId = 'stop':
        ! ====================== REACTION PHOTO: STOP ======================
        ! Фото:
        ! images/events/<girl>/hall_lewd/reaction/uniform<form>_stop.webp
