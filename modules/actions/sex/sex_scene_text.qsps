! ================================================
! FILE: modules/actions/sex/sex_scene_text.qsps
! Индивидуальные тексты для универсальной интимной сцены
! Работает вместе с modules/actions/sex/sex_scene_core.qsps
! Одежда меняется автоматически по стадии сцены
! Беременность пока не обрабатывается
! ================================================

#SexSceneText
    $SexTextAction = LCASE($ARGS[0])

    if $SexTextAction = '':
        $SexTextAction = 'intro'
    end

    if $SexGirl = 'amanda':
        gs 'SexSceneTextAmanda', $SexTextAction
    elseif $SexGirl = 'melissa':
        gs 'SexSceneTextMelissa', $SexTextAction
    elseif $SexGirl = 'sandra':
        gs 'SexSceneTextSandra', $SexTextAction
    elseif $SexGirl = 'becky':
        gs 'SexSceneTextBecky', $SexTextAction
    elseif $SexGirl = 'inga':
        gs 'SexSceneTextInga', $SexTextAction
    elseif $SexGirl = 'clarissa':
        gs 'SexSceneTextClarissa', $SexTextAction
    else:
        gs 'SexSceneTextDefault', $SexTextAction
    end

    killvar '$SexTextAction'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_text.qsps
! Тексты Аманды
! ================================================

#SexSceneTextAmanda
    $SexTextAction = LCASE($ARGS[0])

    if $SexTextAction = 'intro':
        $SexLastText = 'Аманда задерживает на вас взгляд чуть дольше обычного. В её улыбке есть и смущение, и вызов, будто она сама не до конца решила, хочет ли отступить или посмотреть, что будет дальше.'
    elseif $SexTextAction = 'kiss':
        $SexLastText = 'Вы целуете Аманду. Она сперва будто собирается что-то ехидно сказать, но быстро забывает об этом и отвечает на поцелуй куда охотнее, чем хотела показать.'
    elseif $SexTextAction = 'caress':
        $SexLastText = 'Вы касаетесь Аманды осторожно, без спешки. Она фыркает для вида, но не отстраняется, а потом и вовсе сама подаётся ближе.'
    elseif $SexTextAction = 'breast_caress':
        $SexLastText = 'Ваши ласки становятся смелее. Аманда пытается сохранить дерзкий вид, но сбившееся дыхание выдаёт её с головой.'
    elseif $SexTextAction = 'cuni':
        $SexLastText = 'Вы опускаетесь ниже, и Аманда уже не может изображать равнодушие. Она цепляется за вас пальцами и всё чаще забывает, что собиралась держаться уверенно.'
    elseif $SexTextAction = 'blowjob':
        $SexLastText = 'Аманда решается на более смелую ласку. Ей неловко, но любопытство и возбуждение быстро пересиливают смущение.'
    elseif $SexTextAction = 'vaginal':
        $SexLastText = 'Близость с Амандой становится полной. Она уже не только принимает ваши движения, но и сама отвечает на них, будто ей хочется доказать, что она ничуть не робкая.'
    elseif $SexTextAction = 'girl_finish':
        $SexLastText = 'Аманда больше не выдерживает. Её дерзость на миг исчезает, остаётся только горячее смущение и сбившееся дыхание.'
    elseif $SexTextAction = 'player_finish_good':
        $SexLastText = 'Стефан больше не может сдерживаться. Аманда, уже довольная и раскрасневшаяся, смотрит на него с ленивой улыбкой.'
    elseif $SexTextAction = 'player_finish_bad':
        $SexLastText = 'Стефан завершает раньше, чем Аманда успевает получить своё. Она смотрит на него с явным укором и недовольно поправляет волосы.'
    elseif $SexTextAction = 'player_out':
        $SexLastText = 'Стефан пытается продолжить, но сил уже нет. Аманда замечает это и насмешливо улыбается, хотя в её голосе нет настоящей злости.'
    elseif $SexTextAction = 'rest':
        $SexLastText = 'Вы даёте себе немного времени отдышаться. Аманда остаётся рядом и, словно невзначай, проверяет, готовы ли вы продолжать.'
    else:
        $SexLastText = 'Аманда смотрит на вас с любопытной улыбкой, ожидая, что вы сделаете дальше.'
    end

    killvar '$SexTextAction'
