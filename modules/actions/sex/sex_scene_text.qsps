! ================================================
! FILE: modules/actions/sex/sex_scene_text.qsps
! Индивидуальные тексты для универсальной интимной сцены
! Работает вместе с modules/actions/sex/sex_scene_core.qsps
! Одежда меняется автоматически по стадии сцены
! Беременность пока не обрабатывается
! ================================================

#SexSceneText
    $SexTextAction = LCASE($ARGS[0])

    if $SexTextAction = '':
        $SexTextAction = 'intro'
    end

    if $SexTextAction = 'pose_change':
        gs 'SexSceneTextPoseChange'
        killvar '$SexTextAction'
        exit
    end

    if $SexGirl = 'amanda':
        gs 'SexSceneTextAmanda', $SexTextAction
    elseif $SexGirl = 'melissa':
        gs 'SexSceneTextMelissa', $SexTextAction
    elseif $SexGirl = 'sandra':
        gs 'SexSceneTextSandra', $SexTextAction
    elseif $SexGirl = 'becky':
        gs 'SexSceneTextBecky', $SexTextAction
    elseif $SexGirl = 'inga':
        gs 'SexSceneTextInga', $SexTextAction
    elseif $SexGirl = 'clarissa':
        gs 'SexSceneTextClarissa', $SexTextAction
    else:
        gs 'SexSceneTextDefault', $SexTextAction
    end

    killvar '$SexTextAction'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_text.qsps
! Тексты Аманды
! ================================================

#SexSceneTextAmanda
    $SexTextAction = LCASE($ARGS[0])

    if $SexTextAction = 'intro':
        $SexLastText = 'Аманда смотрит на вас с вызовом и смущением. На кровати тихо — за стенкой мама и Мелисса, но сестра явно не собирается останавливаться на полпути.'
    elseif $SexTextAction = 'kiss':
        if SexSceneKissCount = 1:
            $SexLastText = 'Аманда прижимается к вам всем телом и целует отнюдь не по-братски — язык, дыхание, жар кожи. Она фыркает для вида, но отвечает жаднее, чем хотела показать.'
        elseif SexSceneKissCount = 2:
            $SexLastText = 'Вы целуете Аманду в шею — она вздрагивает, прикусывает губу и шепчет: «Тише, дурак…» — но сама тянется ближе.'
        elseif SexSceneKissCount = 3:
            $SexLastText = 'Поцелуй становится глубже: Аманда цепляет вас за ворот, дышит вам в рот и уже не пытается изображать, что это «просто баловство».'
        else
            $SexLastText = 'Вы снова целуете Аманду — она отвечает жадно, царапает вас ногтями по спине и фыркает: «Ну и кто тут распустился…»'
        end
    elseif $SexTextAction = 'grope' or $SexTextAction = 'caress' or $SexTextAction = 'breast_caress':
        if SexSceneGropeCount = 1:
            $SexLastText = 'Ваши руки лезут под одежду Аманды: мялись маленькие груди, теребились соски, пальцы скользнули к мокреющей киске. Она вздрагивает, кусает губу, чтобы не застонать слишком громко.'
        elseif SexSceneGropeCount = 2:
            $SexLastText = 'Вы мнёте грудь Аманды сквозь ткань, крутите твёрдые соски — она выгибается и шипит сквозь зубы: «Не так громко…»'
        elseif SexSceneGropeCount = 3:
            $SexLastText = 'Пальцы скользят по внутренней стороне бёдер Аманды, нащупывают мокрую щель — она раздвигает ноги чуть шире, делая вид, что это случайность.'
        else
            $SexLastText = 'Вы снова лапаете Аманду: грудь, живот, киска — она дрожит, краснеет и уже не может скрыть, как сильно это на неё действует.'
        end
    elseif $SexTextAction = 'cuni':
        if SexSceneCuniCount = 1:
            $SexLastText = 'Вы раздвинули ножки Аманды и лижете её киску — она откинулась на кровать, стонет в подушку и уже не пыталась изображать равнодушие.'
        elseif SexSceneCuniCount = 2:
            $SexLastText = 'Язык кружит клитор Аманды, то нежно, то настойчиво — она вцепилась в простыню, бёдра дёргаются навстречу языку, приглушенные стоны.'
        else
            $SexLastText = 'Вы лижете её пизденку, стараясь языком проникнуть как можно губже — Аманда выгибается, шепчет «тише» и вдавливает вашу голову себе между ног.'
        end
    elseif $SexTextAction = 'blowjob':
        if SexSceneBlowjobCount = 1:
            $SexLastText = 'Аманда опускается на колени, расстегивает вам штаны и осторожно достаёт член. Смущённо, но с жаром берёт головку в рот и начинает сосать, поглядывая на дверь.'
        elseif SexSceneBlowjobCount = 2:
            $SexLastText = 'Аманда сосёт ритмично, облизывает ствол и головку — слюна стекает по подбородку, но она не останавливается, только шипит: «Тише…»'
        elseif SexSceneBlowjobCount = 3:
            $SexLastText = 'Она заглатывает глубже, давится чуть-чуть, краснеет, но не отпускает — рука помогает у основания, взгляд снизу вверх с вызовом.'
        elseif SexSceneBlowjobCount = 4:
            $SexLastText = 'Минет становится жаднее: Аманда ускоряется, облизывает уздечку, сжимает губы плотнее — будто хочет довести вас до предела ртом.'
        else
            $SexLastText = 'Аманда снова берёт вас в рот — уже увереннее, без лишней суеты, сосёт и лижет, стараясь не шуметь за стенкой.'
        end
    elseif $SexTextAction = 'rim':
        $SexLastText = 'Вы развернули Аманду на четвереньки и лижете её анус — она взвизгнула, вцепилась в простыню и зашептала: «Тише… Лизетта говорила, что так тоже можно…»'
    elseif $SexTextAction = 'anal':
        gs 'SexSceneTextAmandaAnal'
    elseif $SexTextAction = 'vaginal':
        gs 'SexSceneTextAmandaVaginal'
    elseif $SexTextAction = 'girl_finish':
        $SexLastText = 'Аманда больше не выдерживает. Её дерзость на миг исчезает, остаётся только горячее смущение и сбившееся дыхание.'
    elseif $SexTextAction = 'player_finish_good':
        $SexLastText = 'Стефан больше не может сдерживаться. Аманда, уже довольная и раскрасневшаяся, смотрит на него с ленивой улыбкой.'
    elseif $SexTextAction = 'player_finish_bad':
        $SexLastText = 'Стефан завершает раньше, чем Аманда успевает получить своё. Она смотрит на него с явным укором и недовольно поправляет волосы.'
    elseif $SexTextAction = 'player_out':
        $SexLastText = 'Стефан пытается продолжить, но сил уже нет. Аманда замечает это и насмешливо улыбается, хотя в её голосе нет настоящей злости.'
    elseif $SexTextAction = 'rest':
        $SexLastText = 'Вы даёте себе немного времени отдышаться. Аманда остаётся рядом и, словно невзначай, проверяет, готов ли ваш член к продолжению.'
    else:
        $SexLastText = 'Аманда смотрит на вас с любопытной улыбкой, ожидая, что вы сделаете дальше.'
    end

    killvar '$SexTextAction'
