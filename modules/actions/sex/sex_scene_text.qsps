            $SexLastText = 'Кларисса встречает вас без притворной скромности. В её взгляде ревность, опыт и готовность взять своё.'
        end
    elseif $SexTextAction = 'kiss':
        $SexLastText = 'Поцелуй с Клариссой жёстче, чем с девчонками из трактира. Она отвечает сразу, будто доказывает что-то самой себе.'
    elseif $SexTextAction = 'caress':
        $SexLastText = 'Ваши руки скользят по Клариссе уверенно. Она не учит вас робости — она учит вас не терять время.'
    elseif $SexTextAction = 'breast_caress':
        $SexLastText = 'Ласки становятся смелее. Кларисса выдыхает и шепчет: "Не останавливайся на полпути."'
    elseif $SexTextAction = 'cuni':
