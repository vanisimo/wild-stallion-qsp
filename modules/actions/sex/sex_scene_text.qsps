! ================================================
! FILE: modules/actions/sex/sex_scene_text.qsps
! Тексты Бекки
! ================================================

#SexSceneTextBecky
    $SexTextAction = LCASE($ARGS[0])

    if $SexTextAction = 'intro':
        if BeckyHomeFirstSexActive = 1:
            $SexLastText = 'Бекки затворяет дверь спальни на щеколду и шепчет: "Тихо… у нас мало времени, пока дети заняты."'
        else:
            $SexLastText = 'Бекки смотрит на вас с тёплой улыбкой опытной женщины — она уже знает, зачем вы пришли, и не делает вид, что смущена.'
        end
    elseif $SexTextAction = 'kiss':
        $SexLastText = 'Вы целуете Бекки. Она отвечает уверенно, без девичьей робости, и сама притягивает вас ближе.'
    elseif $SexTextAction = 'caress':
        $SexLastText = 'Вы ласкаете Бекки неторопливо. Она знает, чего хочет, и мягко направляет ваши руки туда, где ей приятнее всего.'
    elseif $SexTextAction = 'breast_caress':
        $SexLastText = 'Пышная грудь Бекки отвечает на ваши ласки. Она тихо постанывает, стараясь не привлечь внимание всего дома.'
    elseif $SexTextAction = 'cuni':
        $SexLastText = 'Вы опускаетесь ниже, и Бекки уже не пытается сдерживаться. Она цепляется за простыню, чтобы не застонать слишком громко.'
    elseif $SexTextAction = 'blowjob':
        $SexLastText = 'Бекки опускается на колени без лишних слов. Опытная вдова берёт вас в рот уверенно, будто давно ждала этого момента.'
    elseif $SexTextAction = 'vaginal':
        $SexLastText = 'Бекки притягивает вас к себе на кровати. "Только тихо, милый…" — шепчет она, и близость становится полной.'
    elseif $SexTextAction = 'girl_finish':
        $SexLastText = 'Бекки больше не выдерживает. Она кусает губу, чтобы не застонать слишком громко, и долго не может отдышаться.'
    elseif $SexTextAction = 'player_finish_good':
        $SexLastText = 'Стефан завершает, а Бекки прижимается к нему, довольная и чуть смущённая после случившегося.'
    elseif $SexTextAction = 'player_finish_bad':
        $SexLastText = 'Стефан завершает раньше, чем Бекки успевает получить своё. Она смотрит на него с лёгким укором, но без злости.'
    elseif $SexTextAction = 'player_out':
        $SexLastText = 'Стефан слишком вымотан, чтобы продолжать. Бекки замечает это и мягко даёт понять, что на сегодня хватит.'
    elseif $SexTextAction = 'rest':
        $SexLastText = 'Вы переводите дыхание. Бекки остаётся рядом и шепчет: "Тихо… дети ещё могут услышать."'
    else:
        $SexLastText = 'Бекки смотрит на вас с тёплой улыбкой, ожидая вашего следующего шага.'
    end

    killvar '$SexTextAction'
---

#SexSceneTextInga
    $SexTextAction = LCASE($ARGS[0])

    if $SexTextAction = 'intro':
        if IngaBackroomFirstSexActive = 1:
            $SexLastText = 'Инга прижимает вас к ящикам в подсобке и шепчет: "Быстро… мама в зале."'
        else:
            $SexLastText = 'Инга смотрит на вас с тихой решимостью — она выбрала вас, а не Лукаса.'
        end
    elseif $SexTextAction = 'kiss':
        $SexLastText = 'Поцелуй с Ингой осторожный, но она отвечает всё смелее, забывая о стыде.'
    elseif $SexTextAction = 'caress':
        $SexLastText = 'Вы ласкаете Ингу неторопливо. Она вздрагивает и шепчет, чтобы вы были тише.'
    elseif $SexTextAction = 'breast_caress':
        $SexLastText = 'Ваши руки скользят под платье. Инга краснеет, но не отстраняется.'
    elseif $SexTextAction = 'cuni':
        $SexLastText = 'Вы опускаетесь ниже. Инга кусает ладонь, чтобы не выдать себя слишком громким стоном.'
    elseif $SexTextAction = 'blowjob':
        $SexLastText = 'Инга опускается на колени между ящиками — смущённо, но уже без колебаний.'
    elseif $SexTextAction = 'vaginal':
        $SexLastText = 'Близость с Ингой становится полной. Она шепчет ваше имя и больше не сравнивает вас с Лукасом.'
    elseif $SexTextAction = 'girl_finish':
        $SexLastText = 'Инга дрожит в ваших руках и долго не может отдышаться, пряча лицо у вас на плече.'
    elseif $SexTextAction = 'player_finish_good':
        $SexLastText = 'Стефан завершает, а Инга смотрит на него с благодарностью и смущённой нежностью.'
    elseif $SexTextAction = 'player_finish_bad':
        $SexLastText = 'Стефан завершает раньше, чем Инга успевает получить своё. Она молчит, но в глазах — лёгкая обида.'
    elseif $SexTextAction = 'player_out':
        $SexLastText = 'Стефан слишком устал. Инга кивает понимающе: "На сегодня хватит."'
    elseif $SexTextAction = 'rest':
        $SexLastText = 'Вы переводите дыхание. Инга прислушивается к шагам в лавке.'
    else:
        $SexLastText = 'Инга ждёт вашего следующего шага — с тихим волнением.'
    end

    killvar '$SexTextAction'
