        end
    elseif $SexTextAction = 'blowjob':
        if SexSceneBlowjobCount = 1:
            $SexLastText = 'Мелисса долго не решается, но опускается на колени, расстегивает вам штаны и осторожно берёт член в рот. Смущение заметно, но в движениях — осторожная нежность.'
        elseif SexSceneBlowjobCount = 2:
            $SexLastText = 'Мелисса сосёт ритмично, облизывает головку — краснеет, но не останавливается, стараясь не шуметь.'
        elseif SexSceneBlowjobCount = 3:
            $SexLastText = 'Она заглатывает чуть глубже, давится, отводит взгляд — и снова берёт вас в рот упорнее.'
        elseif SexSceneBlowjobCount = 4:
