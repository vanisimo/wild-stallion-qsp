! ================================================
! FILE: modules/actions/sex/sex_scene_text.qsps
! Тексты по умолчанию
! ================================================

#SexSceneTextDefault
    $SexTextAction = LCASE($ARGS[0])

    if $SexTextAction = 'intro':
        $SexLastText = $RealName[$SexGirl] + ' остаётся рядом с вами. Между вами повисает тихое напряжение.'
    elseif $SexTextAction = 'kiss':
        $SexLastText = 'Вы мягко целуете ' + $RealName[$SexGirl] + '. Она отвечает на поцелуй и становится ближе.'
    elseif $SexTextAction = 'caress':
        $SexLastText = 'Вы не торопитесь, позволяя ' + $RealName[$SexGirl] + ' привыкнуть к вашей близости.'
    elseif $SexTextAction = 'breast_caress':
        $SexLastText = 'Ваши ласки становятся смелее, и ' + $RealName[$SexGirl] + ' всё хуже скрывает возбуждение.'
    elseif $SexTextAction = 'cuni':
        $SexLastText = 'Вы переходите к более откровенной ласке. ' + $RealName[$SexGirl] + ' отвечает всё заметнее.'
    elseif $SexTextAction = 'blowjob':
        $SexLastText = $RealName[$SexGirl] + ' решается на более смелую ласку.'
    elseif $SexTextAction = 'vaginal':
        $SexLastText = 'Близость становится полной. ' + $RealName[$SexGirl] + ' сама тянется к вам.'
    elseif $SexTextAction = 'girl_finish':
        $SexLastText = $RealName[$SexGirl] + ' больше не может сдерживаться и дрожит в ваших руках.'
    elseif $SexTextAction = 'player_finish_good':
        $SexLastText = 'Стефан завершает, и ' + $RealName[$SexGirl] + ' выглядит довольной.'
    elseif $SexTextAction = 'player_finish_bad':
        $SexLastText = 'Стефан завершает раньше, чем ' + $RealName[$SexGirl] + ' успевает получить удовольствие.'
    elseif $SexTextAction = 'player_out':
        $SexLastText = 'Стефан слишком вымотан, чтобы продолжать.'
    elseif $SexTextAction = 'rest':
        $SexLastText = 'Вы даёте себе немного времени отдышаться.'
    else:
        $SexLastText = $RealName[$SexGirl] + ' ждёт вашего следующего шага.'
    end

    killvar '$SexTextAction'
