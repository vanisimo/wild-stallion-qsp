! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Завершение сцены
! Если Стефан завершал с девушкой, она блокируется до завтра
! ================================================

#SexSceneEnd
    *clr
    clr
    cla

    gs 'EnsureGirlData', $SexGirl

    *pl '══════════════════════════════════════════════'
    *pl ' ЗАВЕРШЕНИЕ БЛИЗОСТИ'
    *pl '══════════════════════════════════════════════'
    *pl ' '

    if SexSceneHadVaginal = 1:
        gs 'RegisterSex', $SexGirl
    end

    if $SexGirl = 'becky' and BeckyHomeFirstSexActive = 1:
        BeckyHomeFirstSexActive = 0

        if SexSceneHadVaginal = 1:
            BeckyHomeSex = 1

            if BeckyHomeStage < 4:
                BeckyHomeStage = 4
            end
        end
    end

    if $SexGirl = 'amanda' and AmandaHomeFirstSexActive = 1:
        AmandaHomeFirstSexActive = 0

        if SexSceneHadVaginal = 1:
            AmandaHomeSex = 1
            AmandaHomeStage = 7
            AmandaPlayerPath += 2
        end
    end

    if $SexGirl = 'melissa' and MelissaHomeFirstSexActive = 1:
        MelissaHomeFirstSexActive = 0

        if SexSceneHadVaginal = 1:
            MelissaHomeSex = 1
            MelissaHomeStage = 7
            MelissaPlayerPath += 2
        end
    end

    if $SexGirl = 'inga' and IngaBackroomFirstSexActive = 1:
        IngaBackroomFirstSexActive = 0

        if SexSceneHadVaginal = 1:
            IngaBackroomSex = 1
            IngaRomanceStage = 4
            IngaDanceUnlocked = 1
            IngaPlayerPath += 2
            virginity['inga'] = 0
        end
    end

    if $SexGirl = 'sandra' and SandraHomeFirstSexActive = 1:
        SandraHomeFirstSexActive = 0

        if SexSceneHadVaginal = 1:
            SandraHomeSex = 1
            SandraHomeStage = 12
            SandraPlayerPath += 2
        end
    end

    if $SexGirl = 'clarissa' and SexSceneHadVaginal = 1:
        if ClarissaIntimFirstSexActive = 1:
            ClarissaIntimFirstSexActive = 0
            ClarissaIntimSex = 1
            ClarissaIntimStage = 4
            ClarissaPlayerPath += 2
        end

        ClarissaVaginalSexCount += 1
    end

    if SexSceneHadPlayerCum = 1:
        SexUsedToday[$SexGirl] = 1
    end

    if SexSceneHadPlayerCum = 1:
        if SexGirlCameInScene > 0:
            *p $RealName[$SexGirl] + ' выглядит уставшей, но довольной. На сегодня ей явно нужно прийти в себя.'
            Friends[$SexGirl] += 1
            love[$SexGirl] += 1
        else
            *p $RealName[$SexGirl] + ' поправляет одежду и молчит чуть дольше обычного. Кажется, ей хотелось бы большего внимания.'
            Friends[$SexGirl] -= 1
        end
    else
        *p 'Вы решаете остановиться, пока всё не зашло дальше.'
        *p $RealName[$SexGirl] + ' принимает это спокойно.'
        Friends[$SexGirl] += 1
    end

    gs 'ClampGirlSocialStats', $SexGirl

    SexSceneActive = 0
    SexPlayerArousal = 0
    SexGirlArousal = 0
    SexSceneMode = 0

    Arousal['you'] = 0
    Arousal[$SexGirl] = 0

    gs 'Menu.Destroy', 'SexSceneMenu'

    *pl ' '

    gs 'ActUiPrepare', 'Вернуться', 'return'
    act $ActUiLabel, $ActUiIconPath:
        gt $SexReturnLoc
    end
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Ограничение значений сцены
! ================================================

#SexSceneClampValues
    if SexPlayerArousal < 0:
        SexPlayerArousal = 0
    end

    if SexPlayerArousal > 100:
        SexPlayerArousal = 100
    end

    if SexGirlArousal < 0:
        SexGirlArousal = 0
    end

    if SexGirlArousal > 120:
        SexGirlArousal = 120
    end

    if SexClothesStage < 0:
        SexClothesStage = 0
    end

    if SexClothesStage > 2:
        SexClothesStage = 2
    end
