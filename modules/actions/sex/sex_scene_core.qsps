! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Универсальный движок добровольных интимных сцен
! Новая версия:
! - действия открываются по IntimStage
! - одежда меняется автоматически по стадии сцены
! - девушка получает оргазм автоматически при высоком возбуждении
! - Стефан при пределе возбуждения переходит к выбору финала
! - выбор финала может вызвать общий финал
! - после финала девушка блокируется до завтра только если Стефан закончил
! - беременность пока намеренно не обрабатывается
! ================================================

#SexSceneStart
    gs 'NormalizeGirlKey', $ARGS[0]
    $SexGirl = $GirlKey
    $SexReturnLoc = $ARGS[1]
    $SexMode = LCASE($ARGS[2])
    $SexDenyReturnLoc = $CURLOC

    if $SexDenyReturnLoc = '':
        $SexDenyReturnLoc = 'TavernMain'
    end

    if $SexReturnLoc = '':
        $SexReturnLoc = $CURLOC
    end

    if $SexReturnLoc = '':
        $SexReturnLoc = 'TavernMain'
    end

    if $SexMode = '':
        $SexMode = 'normal'
    end

    if $SexGirl = '':
        *clr
        clr
        cla
        *pl 'Ошибка: SexSceneStart вызван без имени девушки.'
        gs 'ActUiPrepare', 'Вернуться', 'return'
        act $ActUiLabel, $ActUiIconPath:
            gt $SexReturnLoc
        end
        exit
    end

    gs 'EnsureGirlData', $SexGirl
    gs 'SexSceneEnsureIntimStage', $SexGirl
    gs 'CanStartSexScene', $SexGirl

    if SexSceneAllowed = 0:
        *clr
        clr
        cla
        *pl '══════════════════════════════════════════════'
        *pl ' ИНТИМНАЯ СЦЕНА'
        *pl '══════════════════════════════════════════════'
        *pl ' '
        *p $SexSceneDenyReason

        if debug = 1:
            *pl ' '
            *pl '[DEBUG] Девушка: ' + $SexGirl
            *pl '[DEBUG] IntimStage: ' + STR(IntimStage[$SexGirl])
            *pl '[DEBUG] Дружба: ' + STR(Friends[$SexGirl])
            *pl '[DEBUG] Любовь: ' + STR(love[$SexGirl])
            *pl '[DEBUG] Откровенность: ' + STR(otkroven[$SexGirl])
            *pl '[DEBUG] Развращённость: ' + STR(sluttiness[$SexGirl])
        end

        gs 'ActUiPrepare', 'Вернуться', 'return'
        act $ActUiLabel, $ActUiIconPath:
            gt $SexDenyReturnLoc
        end
        exit
    end

    gs 'SexSceneInitState', $SexGirl
    gt 'SexSceneMain'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Проверка допуска к сцене
! ================================================

#CanStartSexScene
    gs 'NormalizeGirlKey', $ARGS[0]
    $SexCheckGirl = $GirlKey

    SexSceneAllowed = 1
    $SexSceneDenyReason = ''

    if $SexCheckGirl = '':
        SexSceneAllowed = 0
        $SexSceneDenyReason = 'Ошибка: девушка не выбрана.'
        exit
    end

    if $SexCheckGirl = 'georgett' and GeorgettePortSexPaidActive = 1:
        exit
    end

    if $SexCheckGirl = 'georgett' and GeorgetteChurchSexPaidActive = 1:
        exit
    end

    if $SexCheckGirl = 'becky' and BeckyHomeFirstSexActive = 1:
        exit
    end

    if $SexCheckGirl = 'becky' and BeckyHomeSex = 1:
        exit
    end

    if $SexCheckGirl = 'amanda' and AmandaHomeFirstSexActive = 1:
        exit
    end

    if $SexCheckGirl = 'amanda' and AmandaHomeSex = 1:
        exit
    end

    if $SexCheckGirl = 'amanda' and AmandaHomeAnalActive = 1:
        exit
    end

    if $SexCheckGirl = 'melissa' and MelissaHomeFirstSexActive = 1:
        exit
    end

    if $SexCheckGirl = 'melissa' and MelissaHomeSex = 1:
        exit
    end

    if $SexCheckGirl = 'melissa' and MelissaAnalWithGgActive = 1:
        exit
    end

    if $SexCheckGirl = 'inga' and IngaBackroomFirstSexActive = 1:
        exit
    end

    if $SexCheckGirl = 'inga' and IngaBackroomSex = 1:
        exit
    end

    if $SexCheckGirl = 'sandra' and SandraHomeFirstSexActive = 1:
        exit
    end

    if $SexCheckGirl = 'sandra' and SandraHomeSex = 1:
        exit
    end

    if $SexCheckGirl = 'clarissa' and ClarissaIntimFirstSexActive = 1:
        exit
    end

    if $SexCheckGirl = 'clarissa' and ClarissaIntimSex = 1:
        exit
    end

    if IntimStage[$SexCheckGirl] < 1:
        SexSceneAllowed = 0
        $SexSceneDenyReason = $RealName[$SexCheckGirl] + ' пока не готова к такой близости.'
        exit
    end

    if Friends[$SexCheckGirl] < 20 and love[$SexCheckGirl] < 15:
        SexSceneAllowed = 0
        $SexSceneDenyReason = 'Сейчас между вами недостаточно доверия для такой близости.'
        exit
    end

    if otkroven[$SexCheckGirl] < 10:
        SexSceneAllowed = 0
        $SexSceneDenyReason = $RealName[$SexCheckGirl] + ' пока слишком смущена для такой близости.'
        exit
    end

    killvar '$SexCheckGirl'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Временная поддержка старых данных
! Если IntimStage ещё не задан, стадия выводится из старых отношений
! Позже это можно заменить чистой сюжетной прогрессией
! ================================================

#SexSceneEnsureIntimStage
    gs 'NormalizeGirlKey', $ARGS[0]
    $SexStageGirl = $GirlKey

    if $SexStageGirl = '':
        exit
    end

    if IntimStage[$SexStageGirl] <= 0:
        if sluttiness[$SexStageGirl] >= 60 and otkroven[$SexStageGirl] >= 40 and Friends[$SexStageGirl] >= 45:
            IntimStage[$SexStageGirl] = 5
        elseif sluttiness[$SexStageGirl] >= 45 and otkroven[$SexStageGirl] >= 35:
            IntimStage[$SexStageGirl] = 4
        elseif sluttiness[$SexStageGirl] >= 30 and otkroven[$SexStageGirl] >= 25:
            IntimStage[$SexStageGirl] = 3
        elseif Friends[$SexStageGirl] >= 30 or love[$SexStageGirl] >= 25:
            IntimStage[$SexStageGirl] = 2
        elseif Friends[$SexStageGirl] >= 20 or love[$SexStageGirl] >= 15:
            IntimStage[$SexStageGirl] = 1
        end
    end

    killvar '$SexStageGirl'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Инициализация состояния сцены
! ================================================

#SexSceneInitState
    gs 'NormalizeGirlKey', $ARGS[0]
    $SexGirl = $GirlKey

    SexSceneActive = 1
    SexSceneMode = 0

    SexStage = IntimStage[$SexGirl]
    SexRound = 1
    SexClothesStage = 0

    if SexStage >= 2:
        SexClothesStage = 1
    end

    if SexStage >= 4:
        SexClothesStage = 2
    end

    SexMainStarted = 0
    SexSceneHadVaginal = 0
    SexSceneHadBlowjob = 0
    SexSceneHadRim = 0
    SexSceneHadAnal = 0
    SexSceneHadPlayerCum = 0

    SexPlayerArousal = 5
    SexGirlArousal = 5 + sluttiness[$SexGirl] / 8 + love[$SexGirl] / 15

    if SexGirlArousal > 18:
        SexGirlArousal = 18
    end

    SexPlayerCameInScene = 0
    SexGirlCameInScene = 0
    SexGirlOrgasmStart = GiveOrgasms[$SexGirl]

    SexPlayerRest = 0
    SexPlayerOut = 0
    SexSimultaneousOrgasm = 0

    SexSceneKissCount = 0
    SexSceneGropeCount = 0
    SexSceneBlowjobCount = 0
    SexSceneVaginalCount = 0
    SexSceneCuniCount = 0

    SexKissGirlCap = 38
    SexKissPlayerCap = 35
    SexGropeGirlCap = 58
    SexGropePlayerCap = 52
    SexCuniPlayerCap = 48
    SexPlayerOrgasmFromGirlThreshold = 90
    SexPlayerFinishThreshold = 88

    SexGirlTriggeredPlayerOrgasm = 0
    SexSceneNextPlayerGain = 0
    SexSceneCuniUseCount = 0

    $SexPose = 'missionary'
    $SexActType = 'intro'
    SexSceneReverseCowgirlSlutMin = 40
    SexSceneShowChangePose = 0
    SexSceneAnalCount = 0
    $SexFinishPlace = ''
    $SexLastText = ''

    gs 'SexSceneTextAction', 'intro'
    gs 'SexSceneClampValues'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Главное окно сцены
! ================================================

#SexSceneMain
    *clr
    clr
    cla

    gs 'EnsureGirlData', $SexGirl
    gs 'SexSceneClampValues'
    gs 'SexSceneShowStatusPanel'

    *pl '══════════════════════════════════════════════'
    *pl ' БЛИЗОСТЬ: ' + $RealName[$SexGirl]
    *pl '══════════════════════════════════════════════'
    *pl ' '

    if $SexLastText <> '':
        *p $SexLastText
    else:
        *p $RealName[$SexGirl] + ' смотрит на вас, ожидая вашего следующего шага.'
    end

    *pl ' '
    gs 'SexSceneBuildMenu'
    *p 'Что вы будете <a href="exec:gs ''Menu.Show'', ''SexSceneMenu''">делать</a>?'

    if debug = 1:
        *pl ' '
        *pl '[DEBUG] SexSceneMode: ' + STR(SexSceneMode)
        *pl '[DEBUG] IntimStage: ' + STR(IntimStage[$SexGirl])
        *pl '[DEBUG] SexStage: ' + STR(SexStage)
        *pl '[DEBUG] SexRound: ' + STR(SexRound)
        *pl '[DEBUG] SexClothesStage: ' + STR(SexClothesStage)
        *pl '[DEBUG] SexActType: ' + $SexActType
        *pl '[DEBUG] SexPlayerArousal: ' + STR(SexPlayerArousal)
        *pl '[DEBUG] SexGirlArousal: ' + STR(SexGirlArousal)
        *pl '[DEBUG] SexPlayerCameInScene: ' + STR(SexPlayerCameInScene)
        *pl '[DEBUG] SexGirlCameInScene: ' + STR(SexGirlCameInScene)
        *pl '[DEBUG] SexSceneHadPlayerCum: ' + STR(SexSceneHadPlayerCum)
        *pl '[DEBUG] SexUsedToday: ' + STR(SexUsedToday[$SexGirl])
        *pl '[DEBUG] daily_cum_count: ' + STR(daily_cum_count)
    end
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Дополнительное описание: состояние Стефана и девушки
! ================================================

#SexSceneShowStatusPanel
    PanelCustomActive = 1

    clr

    gs 'EnsureGirlData', $SexGirl

    if $RealName[$SexGirl] <> '':
        gs 'PanelUiHeader', 'БЛИЗОСТЬ: ' + $RealName[$SexGirl]
    else
        gs 'PanelUiHeader', 'БЛИЗОСТЬ'
    end

    gs 'PanelUiDivider'
    pl ' '

    pl 'Возбуждение Стефана: ' + STR(SexPlayerArousal) + ' / 100'
    pl 'Возбуждение ' + $RealName[$SexGirl] + ': ' + STR(SexGirlArousal) + ' / 100'

    if $SexActType = 'vaginal' or $SexActType = 'anal':
        gs 'SexScenePoseStatusLabel'
        pl 'Поза: ' + $SexPoseStatusLabel
        killvar '$SexPoseStatusLabel'
    end

    pl ' '

    SexDailyMax = can_cum_daily

    if SexDailyMax <= 0:
        SexDailyMax = max_daily_cum
    end

    if SexDailyMax <= 0:
        SexDailyMax = 2
    end

    gs 'SexSceneCalcMenuUnlocks'
    gs 'SexSceneStatusText'

    if SexGirlCameInScene > 0:
        pl $RealName[$SexGirl] + ' получила удовольствие: ' + STR(SexGirlCameInScene) + ' раз.'
    end

    if SexPlayerCameInScene > 0:
        pl 'Стефан завершал в этой сцене: ' + STR(SexPlayerCameInScene) + ' раз.'
    end

    pl 'Сегодня Стефан кончил: ' + STR(daily_cum_count) + ' / ' + STR(SexDailyMax) + '.'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Построение меню интимной сцены
! ================================================

#SexSceneBuildMenu
    gs 'Menu.Destroy', 'SexSceneMenu'
    gs 'Menu.Create', 'SexSceneMenu'
    gs 'SexSceneCalcMenuUnlocks'

    SexSceneShowChangePose = 0

    if $SexActType = 'vaginal' or $SexActType = 'anal':
        gs 'SexSceneCalcChangePoseAvailable'

        if SexSceneChangePoseAvailable = 1:
            SexSceneShowChangePose = 1
        end
    end

    if SexSceneMode = 1:
        gs 'SexSceneBuildFinishMenu'
        exit
    end

    if SexSceneMode = 2:
        gs 'SexSceneBuildAfterFinishMenu'
        exit
    end

    gs 'MenuUiAdd', 'SexSceneMenu', 'Осмотреть', 'look'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionLook'
    }

    gs 'MenuUiAdd', 'SexSceneMenu', 'Целовать', 'flirt'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionKiss'
    }
    gs 'Menu.AddCondition', 'SexSceneMenu', "Result=IIF(IntimStage[$SexGirl]>=1,-1,0)"

    gs 'MenuUiAdd', 'SexSceneMenu', 'Лапать', 'flirt'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionCaress'
    }
    gs 'Menu.AddCondition', 'SexSceneMenu', "Result=IIF(IntimStage[$SexGirl]>=2,-1,0)"

    gs 'MenuUiAdd', 'SexSceneMenu', 'Лизать киску', 'intim'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionCuni'
    }
    gs 'Menu.AddCondition', 'SexSceneMenu', "Result=IIF(IntimStage[$SexGirl]>=4 and SexClothesStage>=2,-1,0)"

    gs 'MenuUiAdd', 'SexSceneMenu', 'Минет', 'intim'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionBlowjob'
    }
    gs 'Menu.AddCondition', 'SexSceneMenu', "Result=IIF(IntimStage[$SexGirl]>=4,-1,0)"

    gs 'MenuUiAdd', 'SexSceneMenu', 'Анилингус', 'intim'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionRim'
    }
    gs 'Menu.AddCondition', 'SexSceneMenu', "Result=IIF(SexSceneRimUnlocked=1,-1,0)"

    gs 'MenuUiAdd', 'SexSceneMenu', 'Трахать', 'intim'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionVaginal'
    }
    gs 'Menu.AddCondition', 'SexSceneMenu', "Result=IIF(IntimStage[$SexGirl]>=5 and SexScenePenetrationReady=1,-1,0)"

    gs 'MenuUiAdd', 'SexSceneMenu', 'Анал', 'intim'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionAnal'
    }
    gs 'Menu.AddCondition', 'SexSceneMenu', "Result=IIF(SexSceneAnalUnlocked=1,-1,0)"

    gs 'MenuUiAdd', 'SexSceneMenu', 'Сменить позу', 'flirt'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionChangePose'
    }
    gs 'Menu.AddCondition', 'SexSceneMenu', "Result=IIF(SexSceneShowChangePose=1,-1,0)"

    gs 'MenuUiAdd', 'SexSceneMenu', 'Уйти', 'return'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneEnd'
    }
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Меню выбора финала Стефана
! ================================================

#SexSceneBuildFinishMenu
    if $SexActType = 'blowjob':
        gs 'MenuUiAdd', 'SexSceneMenu', 'Завершить в рот', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'mouth'
        }

        gs 'MenuUiAdd', 'SexSceneMenu', 'Завершить на лицо', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'face'
        }

        gs 'MenuUiAdd', 'SexSceneMenu', 'Завершить на грудь', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'chest'
        }
    elseif $SexActType = 'vaginal':
        gs 'MenuUiAdd', 'SexSceneMenu', 'Кончить в киску', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'inside'
        }

        gs 'MenuUiAdd', 'SexSceneMenu', 'Вынуть и кончить снаружи', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'outside'
        }

        gs 'MenuUiAdd', 'SexSceneMenu', 'Кончить на живот', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'belly'
        }

        gs 'MenuUiAdd', 'SexSceneMenu', 'Кончить на грудь', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'chest'
        }
    elseif $SexActType = 'anal':
        gs 'MenuUiAdd', 'SexSceneMenu', 'Кончить внутрь', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'inside'
        }

        gs 'MenuUiAdd', 'SexSceneMenu', 'Вынуть и кончить снаружи', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'outside'
        }

        gs 'MenuUiAdd', 'SexSceneMenu', 'Кончить на ягодицы', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'belly'
        }
    else
        gs 'MenuUiAdd', 'SexSceneMenu', 'Кончить на тело', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'body'
        }

        gs 'MenuUiAdd', 'SexSceneMenu', 'Кончить снаружи', 'intim'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionFinish', 'outside'
        }
    end

    gs 'MenuUiAdd', 'SexSceneMenu', 'Сдержаться', 'return'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneActionHoldBack'
    }
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Меню после финала Стефана
! ================================================

#SexSceneBuildAfterFinishMenu
    gs 'CanCumToday'

    if Result = 1 or debug = 1:
        gs 'MenuUiAdd', 'SexSceneMenu', 'Передохнуть', 'sleep'
        gs 'Menu.AddModule', 'SexSceneMenu', {
            gt 'SexSceneActionRest'
        }
    end

    gs 'MenuUiAdd', 'SexSceneMenu', 'Уйти', 'return'
    gs 'Menu.AddModule', 'SexSceneMenu', {
        gt 'SexSceneEnd'
    }
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Расчёт видимости пунктов меню
! ================================================

#SexSceneCalcMenuUnlocks
    SexSceneRimUnlocked = 0
    SexSceneAnalUnlocked = 0
    SexSceneAnalWarmed = 0
    SexScenePenetrationReady = 0

    if SexGirlArousal >= 40 and SexPlayerArousal >= 40 and SexClothesStage >= 2:
        SexScenePenetrationReady = 1
    end

    if SexSceneHadBlowjob = 1 or SexSceneHadVaginal = 1 or SexSceneHadRim = 1:
        SexSceneAnalWarmed = 1
    end

    if IntimStage[$SexGirl] >= 4:
        if $SexGirl = 'amanda' and AmandaLizetteAnalTalkDone = 1:
            SexSceneRimUnlocked = 1
        elseif $SexGirl = 'melissa' and MelissaAnalDiscoveryStage >= 3:
            SexSceneRimUnlocked = 1
        elseif $SexGirl <> 'amanda' and $SexGirl <> 'melissa':
            if otkroven[$SexGirl] >= 25 or sluttiness[$SexGirl] >= 35:
                SexSceneRimUnlocked = 1
            end
        end
    end

    if SexScenePenetrationReady = 1 and SexSceneAnalWarmed = 1:
        if AmandaHomeAnalActive = 1 or MelissaAnalWithGgActive = 1:
            SexSceneAnalUnlocked = 1
        elseif $SexGirl = 'amanda':
            if AmandaHomeSex = 1 and AmandaLizetteAnalTalkDone = 1:
                SexSceneAnalUnlocked = 1
            end
        elseif $SexGirl = 'melissa':
            if MelissaHomeSex = 1 and MelissaAnalDiscoveryStage >= 3:
                SexSceneAnalUnlocked = 1
            end
        elseif $SexGirl = 'sandra':
            if HadSex[$SexGirl] > 0 and analvirgin[$SexGirl] = 0:
                SexSceneAnalUnlocked = 1
            end
        elseif analvirgin[$SexGirl] = 0:
            SexSceneAnalUnlocked = 1
        elseif HadSex[$SexGirl] > 0 and sluttiness[$SexGirl] >= 45 and otkroven[$SexGirl] >= 30:
            SexSceneAnalUnlocked = 1
        end
    end
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Действие: осмотреть
! ================================================

#SexSceneActionLook
    $SexPose = 'look'
    $SexActType = 'look'
    gs 'SexSceneTextAction', 'look'
    gt 'SexSceneMain'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Прирост возбуждения ГГ с замедлением на грани
! ================================================

#SexSceneApplyPlayerGain
    SexScenePlayerGain = SexSceneNextPlayerGain
    SexSceneNextPlayerGain = 0

    if SexScenePlayerGain <= 0:
        killvar 'SexScenePlayerGain'
        exit
    end

    if SexPlayerArousal >= 90:
        SexScenePlayerGainHalf = SexScenePlayerGain / 2

        if SexScenePlayerGainHalf < 1:
            SexScenePlayerGainHalf = 1
        end

        SexScenePlayerGain = SexScenePlayerGainHalf
        killvar 'SexScenePlayerGainHalf'
    end

    if SexPlayerArousal < 100:
        SexPlayerArousal += SexScenePlayerGain

        if SexPlayerArousal > 100:
            SexPlayerArousal = 100
        end
    end

    killvar 'SexScenePlayerGain'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Действие: целовать
! ================================================

#SexSceneActionKiss
    $SexPose = 'kiss'
    $SexActType = 'kiss'
    SexSceneKissArousalGain = 0

    if SexPlayerArousal < SexKissPlayerCap:
        SexPlayerArousal += 9

        if SexPlayerArousal > SexKissPlayerCap:
            SexPlayerArousal = SexKissPlayerCap
        end

        SexSceneKissArousalGain = 1
    end

    if SexGirlArousal < SexKissGirlCap:
        SexGirlArousal += 14

        if SexGirlArousal > SexKissGirlCap:
            SexGirlArousal = SexKissGirlCap
        end

        SexSceneKissArousalGain = 1
    end

    SexSceneKissCount += 1

    if SexSceneKissCount > 4:
        SexSceneKissCount = 1
    end

    KissCount[$SexGirl] += 1
    Friends[$SexGirl] += 1

    if SexClothesStage < 1 and KissCount[$SexGirl] >= 3:
        SexClothesStage = 1
    end

    gs 'SexSceneTextAction', 'kiss'

    if SexSceneKissArousalGain = 0:
        $SexLastText += '<br><br>Поцелуи уже почти не разогревают — нужно что-то смелее.'
    end

    killvar 'SexSceneKissArousalGain'
    gs 'SexSceneAfterAction'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Действие: ласкать
! ================================================

#SexSceneActionCaress
    $SexPose = 'grope'
    $SexActType = 'grope'
    SexSceneGropeArousalGain = 0

    if SexPlayerArousal < SexGropePlayerCap:
        SexPlayerArousal += 10

        if SexPlayerArousal > SexGropePlayerCap:
            SexPlayerArousal = SexGropePlayerCap
        end

        SexSceneGropeArousalGain = 1
    end

    if SexGirlArousal < SexGropeGirlCap:
        SexGirlArousal += 12

        if SexGirlArousal > SexGropeGirlCap:
            SexGirlArousal = SexGropeGirlCap
        end

        SexSceneGropeArousalGain = 1
    end

    SexSceneGropeCount += 1

    if SexSceneGropeCount > 4:
        SexSceneGropeCount = 1
    end

    CaressCount[$SexGirl] += 1
    DeepCaressCount[$SexGirl] += 1
    otkroven[$SexGirl] += 1

    if SexClothesStage < 1:
        SexClothesStage = 1
    elseif SexClothesStage < 2 and SexGirlArousal >= 35:
        SexClothesStage = 2
    end

    gs 'SexSceneTextAction', 'grope'

    if SexSceneGropeArousalGain = 0:
        $SexLastText += '<br><br>Ласки руками больше почти не поднимают жар — пора переходить к делу.'
    end

    killvar 'SexSceneGropeArousalGain'
    gs 'SexSceneAfterAction'
---

! ================================================
! FILE: modules/actions/sex/sex_scene_core.qsps
! Действие: кунилингус
! ================================================

#SexSceneActionCuni
    $SexPose = 'cuni'
