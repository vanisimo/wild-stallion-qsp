        AmandaHomeAnalActive = 0

        if SexSceneHadAnal = 1:
            AmandaHomeAnalDone = 1
            analvirgin['amanda'] = 0
            gs 'RegisterSex', 'amanda', 'anal', 1, 1
            sluttiness['amanda'] += 2
            AmandaPlayerPath += 1
            SexSceneAnalRegistered = 1
        end
    end

    if $SexGirl = 'melissa' and MelissaAnalWithGgActive = 1:
        MelissaAnalWithGgActive = 0

        if SexSceneHadAnal = 1:
            MelissaAnalWithGgDone = 1
            analvirgin['melissa'] = 0
            gs 'RegisterSex', 'melissa', 'anal', 1, 1
            sluttiness['melissa'] += 2
            MelissaPlayerPath += 2
            SexSceneAnalRegistered = 1
        end
    end

    if SexSceneHadAnal = 1 and SexSceneAnalRegistered = 0:
        gs 'RegisterSex', $SexGirl, 'anal', 0, 1
    end

    killvar 'SexSceneAnalRegistered'

    gs 'SexSceneGoodbyeText'

    *p $SexGoodbyeText

    if SexSceneHadPlayerCum = 0:
        Friends[$SexGirl] += 1
    elseif SexGirlCameInScene = 0:
        SexGoodbyeFriendsDelta = -1

        if $SexGirl = 'amanda' and SexPlayerCameInScene > 0:
            SexGoodbyeFriendsDelta = -2
        end

        Friends[$SexGirl] += SexGoodbyeFriendsDelta
    elseif SexGirlCameInScene >= 4:
        Friends[$SexGirl] += 2
        love[$SexGirl] += 1
        otkroven[$SexGirl] += 1
    elseif SexGirlCameInScene >= 2:
        Friends[$SexGirl] += 1
        love[$SexGirl] += 1
    elseif SexGirlCameInScene = 1:
        Friends[$SexGirl] += 1
    end

    gs 'ClampGirlSocialStats', $SexGirl

    killvar '$SexGoodbyeText'
    killvar 'SexGoodbyeFriendsDelta'

    SexSceneActive = 0
    SexPlayerArousal = 0
    SexGirlArousal = 0
    SexSceneMode = 0

    Arousal['you'] = 0
    Arousal[$SexGirl] = 0

    gs 'Menu.Destroy', 'SexSceneMenu'

    *pl ' '

    gs 'ActUiPrepare', 'Вернуться', 'return'
    act $ActUiLabel, $ActUiIconPath:
        gt $SexReturnLoc
    end
---

