    gs 'GirlTalkGeorgettePrintText', 'georgette_family', 'intro'
    gs 'GirlTalkGeorgettePrintText', 'georgette_family', 'context'

    GeorgetteTalkFamilyDone = 1
    Friends['georgett'] += 1
    otkroven['georgett'] += 2

