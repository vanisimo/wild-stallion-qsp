    gs 'GirlTalkGeorgettePrintText', 'georgette_priest_spy', 'intro'
    gs 'GirlTalkGeorgettePrintText', 'georgette_priest_spy', 'context'

    GeorgetteTalkPriestSpyDone = 1
    Friends['georgett'] += 1
    otkroven['georgett'] += 2

    gs 'ClampGirlSocialStats', 'georgett'
