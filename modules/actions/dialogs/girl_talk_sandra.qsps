! ================================================
! FILE: modules/actions/dialogs/girl_talk_sandra.qsps
! MODULE: actions/dialogs
! Меню и разговоры Сандры как матери семьи
! ================================================

#GirlTalkBuildSandraMainMenu
    gs 'Menu.Destroy', 'GirlTalkMainMenu'
    gs 'Menu.Create', 'GirlTalkMainMenu'

    if $GirlLocation['sandra'] = 'Kitchen':
        gs 'MenuUiAdd', 'GirlTalkMainMenu', 'О кухне и трактире', ''
    else:
        gs 'MenuUiAdd', 'GirlTalkMainMenu', 'О работе трактира', ''
    end

    gs 'Menu.AddModule', 'GirlTalkMainMenu', {
        gt 'GirlTalkResult', $TalkGirl, $TalkReturnLoc, 'tavern'
    }

    gs 'MenuUiAdd', 'GirlTalkMainMenu', 'О доме', ''
    gs 'Menu.AddModule', 'GirlTalkMainMenu', {
        gt 'GirlTalkResult', $TalkGirl, $TalkReturnLoc, 'family'
    }

    gs 'MenuUiAdd', 'GirlTalkMainMenu', 'О дочерях', ''
    gs 'Menu.AddModule', 'GirlTalkMainMenu', {
        gt 'GirlTalkResult', $TalkGirl, $TalkReturnLoc, 'daughters'
    }

    gs 'MenuUiAdd', 'GirlTalkMainMenu', 'Поболтать ни о чём', ''
    gs 'Menu.AddModule', 'GirlTalkMainMenu', {
        gt 'GirlTalkResult', $TalkGirl, $TalkReturnLoc, 'smalltalk'
    }

    if GirlTalkHallTopicsAvailable = 1:
        gs 'MenuUiAdd', 'GirlTalkMainMenu', 'О событиях в зале', ''
        gs 'Menu.AddModule', 'GirlTalkMainMenu', {
            gs 'GirlTalkBuildHallTopicsMenu'
            gs 'Menu.Show', 'GirlTalkHallTopicsMenu'
        }
    end

    if GirlTalkPersonalAvailable = 1:
        gs 'MenuUiAdd', 'GirlTalkMainMenu', 'Личный разговор', ''
        gs 'Menu.AddModule', 'GirlTalkMainMenu', {
            gs 'GirlTalkPersonalBuildMenu'
            gs 'Menu.Show', 'GirlTalkPersonalMenu'
        }
    end

    if LOC('SandraBirthRevealCanTalk') = 1:
        gs 'SandraBirthRevealCanTalk'

        if SandraBirthRevealCanTalk = 1:
            gs 'MenuUiAdd', 'GirlTalkMainMenu', 'О том, что случилось в зале', ''
            gs 'Menu.AddModule', 'GirlTalkMainMenu', {
                gt 'SandraTalkAboutBirthSecret', $TalkReturnLoc
            }
        end
    end

    if LOC('SandraStaffHireCanTalk') = 1:
        gs 'SandraStaffHireCanTalk'

        if SandraStaffHireCanTalk = 1:
            gs 'MenuUiAdd', 'GirlTalkMainMenu', 'О помощницах для трактира', ''
            gs 'Menu.AddModule', 'GirlTalkMainMenu', {
                gt 'SandraStaffHireTalk', $TalkReturnLoc
            }
        end
    end

    if LOC('SandraStaffGirlsReactionCanTalk') = 1:
        gs 'SandraStaffGirlsReactionCanTalk', 'sandra'

        if SandraStaffGirlsReactionCanTalk = 1:
            gs 'MenuUiAdd', 'GirlTalkMainMenu', 'После помощниц матери', ''
            gs 'Menu.AddModule', 'GirlTalkMainMenu', {
                gt 'SandraStaffGirlsReactionTalk', 'sandra', $TalkReturnLoc
            }
        end
    end

    if Friends['sandra'] >= 18 or otkroven['sandra'] >= 18 or love['sandra'] >= 12:
        gs 'MenuUiAdd', 'GirlTalkMainMenu', 'Сделать комплимент', ''
        gs 'Menu.AddModule', 'GirlTalkMainMenu', {
            gt 'GirlTalkResult', $TalkGirl, $TalkReturnLoc, 'compliment'
        }
    end

    if LOC('SandraBeckyCrisisCanTalk') = 1:
        gs 'SandraBeckyCrisisCanTalk'

        if SandraBeckyCrisisCanTalk = 1:
            gs 'MenuUiAdd', 'GirlTalkMainMenu', 'Сандра хочет выяснить отношения', ''
            gs 'Menu.AddModule', 'GirlTalkMainMenu', {
                gt 'SandraBeckyCrisisStart'
            }
        end
    end

---

#GirlTalkDaughtersRun
    gs 'GirlTalkDaughtersPrintText', 'intro'
    gs 'GirlTalkDaughtersPrintText', 'context'

    Friends['sandra'] += 1

    if SandraFamilyConcern > 0:
        SandraFamilyConcern -= 1

        if SandraFamilyConcern < 0:
            SandraFamilyConcern = 0
        end
    end
---

#GirlTalkDaughtersPrintText
    gs 'GirlTalkDaughtersText', $ARGS[0]

    if $GirlTalkDaughtersText <> '':
        *p $GirlTalkDaughtersText
    end

    killvar '$GirlTalkDaughtersText'
---