    $NpcIntimOpenLabel = $ARGS[0]
    $NpcIntimOpenGirl = LCASE($ARGS[1])
    $NpcIntimOpenLoc = $ARGS[2]
    $NpcIntimOpenOutput = LCASE($ARGS[3])

    if $NpcIntimOpenGirl = '' or $NpcIntimOpenLabel = '':
        killvar '$NpcIntimOpenLabel'
        killvar '$NpcIntimOpenGirl'
        killvar '$NpcIntimOpenLoc'
        killvar '$NpcIntimOpenOutput'
        exit
    end

    if $NpcIntimOpenLoc = '':
