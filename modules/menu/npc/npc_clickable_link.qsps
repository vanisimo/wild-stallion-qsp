    end

    if $NpcIntimOpenOutput = '':
        $NpcIntimOpenOutput = 'main'
    end

    gs 'FormatTextByStyle', $NpcIntimOpenLabel, 'npc_link'
    $NpcIntimOpenHref = '<a href="exec:gs ''GirlIntimOpenNpcMenu'', ''' + $NpcIntimOpenGirl + ''', ''' + $NpcIntimOpenLoc + '''">' + $FormattedText + '</a>'
    killvar '$FormattedText'

    gs 'NpcIntimIconInline'
    $NpcIntimOpenLine = $NpcIntimIconInline + ' ' + $NpcIntimOpenHref

    killvar '$NpcIntimOpenLabel'
    killvar '$NpcIntimOpenGirl'
    killvar '$NpcIntimOpenLoc'
    killvar '$NpcIntimOpenOutput'
    killvar '$NpcIntimOpenHref'
    killvar '$NpcIntimIconInline'
    killvar '$NpcIntimOpenLine'
---

#NpcMenuIntimOpenIconLink
    $NpcIntimIconGirl = LCASE($ARGS[0])
    $NpcIntimIconLoc = $ARGS[1]
    $NpcIntimIconOutput = LCASE($ARGS[2])
    $NpcIntimIconReturnLoc = $ARGS[3]

    if $NpcIntimIconGirl = '':
        killvar '$NpcIntimIconGirl'
        killvar '$NpcIntimIconLoc'
        killvar '$NpcIntimIconOutput'
        exit
    end

    if $NpcIntimIconLoc = '':
        $NpcIntimIconLoc = $CURLOC
    end

    if $NpcIntimIconOutput = '':
        $NpcIntimIconOutput = 'main'
    end

    if $NpcIntimIconReturnLoc = '':
        $NpcIntimIconReturnLoc = $NpcIntimIconLoc
    end

    gs 'NpcIntimIconInline'
    $NpcIntimOpenIconLine = '<a href="exec:gs ''GirlIntimOpenNpcMenu'', ''' + $NpcIntimIconGirl + ''', ''' + $NpcIntimIconLoc + ''', ''' + $NpcIntimIconReturnLoc + '''">' + $NpcIntimIconInline + '</a>'

    killvar '$NpcIntimIconGirl'
    killvar '$NpcIntimIconLoc'
    killvar '$NpcIntimIconOutput'
    killvar '$NpcIntimIconReturnLoc'
    killvar '$NpcIntimIconInline'
---

#NpcMenuLink
    $NpcMenuLabel = $ARGS[0]
    $NpcMenuName = $ARGS[1]
    $NpcMenuOutputTarget = LCASE($ARGS[2])

    if $NpcMenuLabel = '' or $NpcMenuName = '':
        killvar '$NpcMenuLabel'
        killvar '$NpcMenuName'
        killvar '$NpcMenuOutputTarget'
        exit
    end

    if $NpcMenuOutputTarget = '':
        $NpcMenuOutputTarget = 'main'
    end

    gs 'FormatTextByStyle', $NpcMenuLabel, 'npc_link'
    $NpcMenuHref = '<a href="exec:gs ''Menu.Show'', ''' + $NpcMenuName + '''">' + $FormattedText + '</a>'
    killvar '$FormattedText'

    gs 'NpcTalkIconInline'
    $NpcMenuLine = $NpcTalkIconInline + ' ' + $NpcMenuHref

    if $NpcMenuOutputTarget = 'panel':
        pl $NpcMenuLine
    else:
        *pl $NpcMenuLine
    end

    killvar '$NpcMenuLabel'
    killvar '$NpcMenuName'
    killvar '$NpcMenuOutputTarget'
    killvar '$NpcMenuHref'
    killvar '$NpcTalkIconInline'
    killvar '$NpcMenuLine'
---

#NpcMenuIntimLink
    $NpcIntimMenuLabel = $ARGS[0]
    $NpcIntimMenuName = $ARGS[1]
    $NpcIntimMenuOutputTarget = LCASE($ARGS[2])

    if $NpcIntimMenuLabel = '' or $NpcIntimMenuName = '':
        killvar '$NpcIntimMenuLabel'
        killvar '$NpcIntimMenuName'
        killvar '$NpcIntimMenuOutputTarget'
        exit
    end

    if $NpcIntimMenuOutputTarget = '':
        $NpcIntimMenuOutputTarget = 'main'
    end

    gs 'FormatTextByStyle', $NpcIntimMenuLabel, 'npc_link'
    $NpcIntimMenuHref = '<a href="exec:gs ''Menu.Show'', ''' + $NpcIntimMenuName + '''">' + $FormattedText + '</a>'
    killvar '$FormattedText'

    gs 'NpcIntimIconInline'
    $NpcIntimMenuLine = $NpcIntimIconInline + ' ' + $NpcIntimMenuHref

    if $NpcIntimMenuOutputTarget = 'panel':
        pl $NpcIntimMenuLine
    else:
        *pl $NpcIntimMenuLine
    end

    killvar '$NpcIntimMenuLabel'
    killvar '$NpcIntimMenuName'
    killvar '$NpcIntimMenuOutputTarget'
    killvar '$NpcIntimMenuHref'
    killvar '$NpcIntimIconInline'
    killvar '$NpcIntimMenuLine'
---

#NpcNavLink
    $NpcNavLabel = $ARGS[0]
    $NpcNavIcon = LCASE($ARGS[1])
    $NpcNavExec = $ARGS[2]
    $NpcNavOutputTarget = LCASE($ARGS[3])

    if $NpcNavLabel = '' or $NpcNavExec = '':
        killvar '$NpcNavLabel'
        killvar '$NpcNavIcon'
        killvar '$NpcNavExec'
        killvar '$NpcNavOutputTarget'
        exit
    end

    if $NpcNavOutputTarget = '':
        $NpcNavOutputTarget = 'main'
    end

    gs 'FormatTextByStyle', $NpcNavLabel, 'npc_link'
    $NpcNavHref = '<a href="exec:' + $NpcNavExec + '">' + $FormattedText + '</a>'
    killvar '$FormattedText'

    if $NpcNavIcon = 'intim':
        gs 'NpcIntimIconInline'
        $NpcNavIconInline = $NpcIntimIconInline
    else:
        gs 'NpcTalkIconInline'
        $NpcNavIconInline = $NpcTalkIconInline
    end

    $NpcNavLine = $NpcNavIconInline + ' ' + $NpcNavHref

    if $NpcNavOutputTarget = 'panel':
        pl $NpcNavLine
    else:
        *pl $NpcNavLine
    end

    killvar '$NpcNavLabel'
    killvar '$NpcNavIcon'
    killvar '$NpcNavExec'
    killvar '$NpcNavOutputTarget'
    killvar '$NpcNavHref'
    killvar '$NpcNavIconInline'
    killvar '$NpcNavLine'
---

#PrintMenuOpenLink
    $PrintMenuOpenName = $ARGS[0]
    $PrintMenuOpenLabel = $ARGS[1]

    if $PrintMenuOpenName = '':
        killvar '$PrintMenuOpenName'
        killvar '$PrintMenuOpenLabel'
        exit
    end

    if $PrintMenuOpenLabel = '':
        $PrintMenuOpenLabel = 'выбрать действие'
    end

    gs 'FormatTextByStyle', $PrintMenuOpenLabel, 'npc_link'
    $PrintMenuOpenHref = '<a href="exec:gs ''Menu.Show'', ''' + $PrintMenuOpenName + '''">' + $FormattedText + '</a>'
    killvar '$FormattedText'

    gs 'NpcTalkIconInline'
    *p $NpcTalkIconInline + ' ' + $PrintMenuOpenHref

    killvar '$PrintMenuOpenName'
    killvar '$PrintMenuOpenLabel'
    killvar '$PrintMenuOpenHref'
    killvar '$NpcTalkIconInline'
---