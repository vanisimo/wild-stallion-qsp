! ================================================
! FILE: modules/menu/npc/npc_clickable_link.qsps
! Кликабельные имена NPC: иконка «поболтать» + синее крупное имя
! ================================================

#NpcTalkIconInline
    $NpcTalkIconInline = '<img src="images/common/ui/actions/talk.png" width="18">'
---

#NpcIntimIconInline
    $NpcIntimIconInline = '<img src="images/common/ui/actions/intim.png" width="18">'
---

#FormatNpcIntimLink
    $FmtNpcIntimKey = LCASE($ARGS[0])
    $FmtNpcIntimExec = $ARGS[1]

    if $FmtNpcIntimKey = '':
        killvar '$FmtNpcIntimKey'
        killvar '$FmtNpcIntimExec'
        exit
    end

    if $RealName[$FmtNpcIntimKey] = '':
        $RealName[$FmtNpcIntimKey] = UCASE(MID($FmtNpcIntimKey, 1, 1)) + LCASE(MID($FmtNpcIntimKey, 2))
    end

    if $FmtNpcIntimExec = '':
        $FmtNpcIntimExec = 'gt ''GirlIntimClosedScreen'', ''' + $FmtNpcIntimKey + ''', ''' + $CURLOC + ''''
    end

    gs 'FormatTextByStyle', $RealName[$FmtNpcIntimKey], 'npc_link'
    $FmtNpcIntimLink = '<a href="exec:' + $FmtNpcIntimExec + '">' + $FormattedText + '</a>'
    killvar '$FormattedText'

    gs 'NpcIntimIconInline'
    $NpcIntimLink = $NpcIntimIconInline + ' ' + $FmtNpcIntimLink

    killvar '$FmtNpcIntimKey'
    killvar '$FmtNpcIntimExec'
    killvar '$FmtNpcIntimLink'
    killvar '$NpcIntimIconInline'
---

#FormatNpcTalkLink
    $FmtNpcTalkKey = LCASE($ARGS[0])
    $FmtNpcTalkExec = $ARGS[1]

    if $FmtNpcTalkKey = '':
        killvar '$FmtNpcTalkKey'
        killvar '$FmtNpcTalkExec'
        exit
    end

    if $RealName[$FmtNpcTalkKey] = '':
        $RealName[$FmtNpcTalkKey] = UCASE(MID($FmtNpcTalkKey, 1, 1)) + LCASE(MID($FmtNpcTalkKey, 2))
    end

    if $FmtNpcTalkExec = '':
        $FmtNpcTalkExec = 'gs ''NPC_Click'', ''' + $FmtNpcTalkKey + ''''
    end

    gs 'FormatTextByStyle', $RealName[$FmtNpcTalkKey], 'npc_link'
    $FmtNpcTalkLink = '<a href="exec:' + $FmtNpcTalkExec + '">' + $FormattedText + '</a>'
    killvar '$FormattedText'

    gs 'NpcTalkIconInline'
    $NpcTalkLink = $NpcTalkIconInline + ' ' + $FmtNpcTalkLink

    killvar '$FmtNpcTalkKey'
    killvar '$FmtNpcTalkExec'
    killvar '$FmtNpcTalkLink'
    killvar '$NpcTalkIconInline'
---

#NpcClickableLink
    $group = LCASE($Args[0])

    if $group = 'family' or $group = 'семья':
        gs 'NpcClickableLink', 'sandra'
        gs 'NpcClickableLink', 'melissa'
        gs 'NpcClickableLink', 'amanda'
        killvar '$group'
        exit
    end

    if $group = 'all' or $group = 'все' or $group = 'girls':
        counter = 0
        :loopgirls
        if counter < arrsize('$AllGirlNames'):
            gs 'NpcClickableLink', $AllGirlNames[counter]
            counter += 1
            jump 'loopgirls'
        end
        killvar '$group'
        exit
    end

    $girl = LCASE($Args[0])
    gs 'FormatNpcTalkLink', $girl
    *pl $NpcTalkLink
    killvar '$girl'
    killvar '$group'
    killvar '$NpcTalkLink'
---

#NpcMenuTalkOpenLink
    $NpcTalkOpenLabel = $ARGS[0]
    $NpcTalkOpenGirl = LCASE($ARGS[1])
    $NpcTalkOpenLoc = $ARGS[2]
    $NpcTalkOpenOutput = LCASE($ARGS[3])
    $NpcTalkOpenReturnLoc = $ARGS[4]

    if $NpcTalkOpenGirl = '' or $NpcTalkOpenLabel = '':
        killvar '$NpcTalkOpenLabel'
        killvar '$NpcTalkOpenGirl'
        killvar '$NpcTalkOpenLoc'
        killvar '$NpcTalkOpenOutput'
        exit
    end

    if $NpcTalkOpenLoc = '':
        $NpcTalkOpenLoc = $CURLOC
    end

    if $NpcTalkOpenOutput = '':
        $NpcTalkOpenOutput = 'main'
    end

    if $NpcTalkOpenReturnLoc = '':
        $NpcTalkOpenReturnLoc = $NpcTalkOpenLoc
    end

    gs 'FormatTextByStyle', $NpcTalkOpenLabel, 'npc_link'
    $NpcTalkOpenHref = '<a href="exec:gs ''GirlTalkOpenNpcMenu'', ''' + $NpcTalkOpenGirl + ''', ''' + $NpcTalkOpenLoc + ''', ''' + $NpcTalkOpenReturnLoc + '''">' + $FormattedText + '</a>'
    killvar '$FormattedText'

    gs 'NpcTalkIconInline'
    $NpcTalkOpenLine = $NpcTalkIconInline + ' ' + $NpcTalkOpenHref

    killvar '$NpcTalkOpenLabel'
    killvar '$NpcTalkOpenGirl'
    killvar '$NpcTalkOpenLoc'
    killvar '$NpcTalkOpenOutput'
    killvar '$NpcTalkOpenReturnLoc'
    killvar '$NpcTalkOpenHref'
    killvar '$NpcTalkIconInline'
---

