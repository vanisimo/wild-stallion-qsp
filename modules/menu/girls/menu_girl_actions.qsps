        act '<b>Поговорить о делах семьи</b>':
            *p 'Вы обсуждаете с Сандрой дела семьи и трактира.'

            Friends['sandra'] += 1
            management_skill += 1

            act '<b>Продолжить</b>':
                gt $GirlReturnLoc
            end
        end
    end

    if sluttiness['sandra'] >= 20:
        act '<b>Личный разговор с Сандрой</b>':
            *p 'Разговор с Сандрой становится более личным, чем обычно.'

            otkroven['sandra'] += 1

            act '<b>Продолжить</b>':
                gt $GirlReturnLoc
            end
        end
    end
