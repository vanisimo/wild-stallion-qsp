                AlleyRisk += 15

                if groupsex[$GirlName] >= 5 and Rand(1,100) <= 65:
                    *p 'Аманда: «Может… позовём их?»'
                    gs 'ActUiPrepare', 'Позвать прохожих', 'generic'
                    act $ActUiLabel, $ActUiIconPath:
