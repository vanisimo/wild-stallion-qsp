! ================================================
! FILE: modules/core/tavern/tavern_hired_staff.qsps
! MODULE: core/tavern
! Безликий наёмный персонал трактира
! Снимает часть перегрузки с девушек, даёт базовую силу работ
! Ежедневная плата списывается в tavern_daily_expenses
! ================================================

#InitTavernHiredStaff
    if TavernHiredKitchen < 0:
        TavernHiredKitchen = 0
    end

    if TavernHiredWaitress < 0:
        TavernHiredWaitress = 0
    end

    if TavernHiredCleaning < 0:
        TavernHiredCleaning = 0
    end

    if TavernHiredKitchenPower <= 0:
        TavernHiredKitchenPower = 28
    end

    if TavernHiredWaitressPower <= 0:
        TavernHiredWaitressPower = 25
    end

    if TavernHiredCleaningPower <= 0:
        TavernHiredCleaningPower = 22
    end

    if TavernHiredKitchenCost <= 0:
        TavernHiredKitchenCost = 12
    end

    if TavernHiredWaitressCost <= 0:
        TavernHiredWaitressCost = 12
    end

    if TavernHiredCleaningCost <= 0:
        TavernHiredCleaningCost = 10
    end

    if TavernHiredOverloadRelief <= 0:
        TavernHiredOverloadRelief = 5
    end
---

! ================================================
! FILE: modules/core/tavern/tavern_hired_staff.qsps
! Применить силу наёмников и снять штраф перегрузки
! Вызывается из CalculateTavernStaffEfficiency
! ================================================

#ApplyTavernHiredStaffEffects
    gs 'InitTavernHiredStaff'

    tavern_hired_staff_count = 0
    tavern_hired_staff_daily_cost = 0

    if TavernHiredKitchen = 1:
        tavern_kitchen_power += TavernHiredKitchenPower
        tavern_hired_staff_count += 1
        tavern_hired_staff_daily_cost += TavernHiredKitchenCost
    end

    if TavernHiredWaitress = 1:
        tavern_waitress_power += TavernHiredWaitressPower
        tavern_hired_staff_count += 1
        tavern_hired_staff_daily_cost += TavernHiredWaitressCost
    end

    if TavernHiredCleaning = 1:
        tavern_cleaning_power += TavernHiredCleaningPower
        tavern_hired_staff_count += 1
        tavern_hired_staff_daily_cost += TavernHiredCleaningCost
    end

    if tavern_hired_staff_count > 0 and tavern_overload_penalty > 0:
        tavern_overload_penalty -= tavern_hired_staff_count * TavernHiredOverloadRelief

        if tavern_overload_penalty < 0:
            tavern_overload_penalty = 0
        end
    end

    tavern_work_efficiency = (tavern_kitchen_power + tavern_waitress_power + tavern_cleaning_power) / 3
    tavern_work_efficiency -= tavern_missing_work_penalty
    tavern_work_efficiency -= tavern_overload_penalty

    if tavern_work_efficiency > 100:
        tavern_work_efficiency = 100
    end

    if tavern_work_efficiency < 0:
        tavern_work_efficiency = 0
    end
---

! ================================================
! FILE: modules/core/tavern/tavern_hired_staff.qsps
! Ежедневные расходы на наёмников
! ================================================

#AddTavernHiredStaffExpenses
    gs 'InitTavernHiredStaff'

    tavern_hired_staff_daily_cost = 0

    if TavernHiredKitchen = 1:
        tavern_hired_staff_daily_cost += TavernHiredKitchenCost
    end

    if TavernHiredWaitress = 1:
        tavern_hired_staff_daily_cost += TavernHiredWaitressCost
    end

    if TavernHiredCleaning = 1:
        tavern_hired_staff_daily_cost += TavernHiredCleaningCost
    end

    tavern_daily_expenses += tavern_hired_staff_daily_cost
---

! ================================================
! FILE: modules/core/tavern/tavern_hired_staff.qsps
! Переключить наёмника на роли из панели персонала
! ARGS[0] — kitchen / waitress / cleaning
! ================================================

#PanelHiredStaffToggle
    $PanelHiredJob = LCASE($ARGS[0])

    if $PanelHiredJob = '':
        exit
    end

    gs 'InitTavernHiredStaff'

    if $PanelHiredJob = 'kitchen':
        if TavernHiredKitchen = 1:
            TavernHiredKitchen = 0
        else
            TavernHiredKitchen = 1
        end

    elseif $PanelHiredJob = 'waitress':
        if TavernHiredWaitress = 1:
            TavernHiredWaitress = 0
        else
            TavernHiredWaitress = 1
        end

    elseif $PanelHiredJob = 'cleaning':
        if TavernHiredCleaning = 1:
            TavernHiredCleaning = 0
        else
            TavernHiredCleaning = 1
        end
    end

    $PanelReturnLoc = $CURLOC

    if $PanelReturnLoc = '':
        $PanelReturnLoc = 'TavernMain'
    end

    gs 'CalculateTavernStaffEfficiency'
    gs 'UpdateGirlLocations'

    $PanelRestoreAfterRefresh = 'staff'

    gt $PanelReturnLoc

    killvar '$PanelHiredJob'
---

! ================================================
! FILE: modules/core/tavern/tavern_hired_staff.qsps
! Блок панели персонала
! ================================================

#PanelHiredStaffBlock
    gs 'InitTavernHiredStaff'
    gs 'CalculateTavernStaffEfficiency'

    pl 'Наёмный персонал:'
    pl 'Дешёвые работники без имени. Снимают часть перегрузки с семьи.'
    pl ' '

    gs 'PanelHiredStaffLine', 'kitchen'
    gs 'PanelHiredStaffLine', 'waitress'
    gs 'PanelHiredStaffLine', 'cleaning'

    if tavern_hired_staff_daily_cost > 0:
        pl 'Расход на наёмников за день: ' + STR(tavern_hired_staff_daily_cost) + ' мараведи'
    end

    pl ' '
---

#PanelHiredStaffLine
    $PanelHiredJob = LCASE($ARGS[0])

    if $PanelHiredJob = '':
        exit
    end

    gs 'InitTavernHiredStaff'

    $PanelHiredJobTitle = ''
    PanelHiredJobActive = 0
    PanelHiredJobPower = 0
    PanelHiredJobCost = 0

    if $PanelHiredJob = 'kitchen':
        $PanelHiredJobTitle = 'Кухня'
        PanelHiredJobActive = TavernHiredKitchen
        PanelHiredJobPower = TavernHiredKitchenPower
        PanelHiredJobCost = TavernHiredKitchenCost

    elseif $PanelHiredJob = 'waitress':
        $PanelHiredJobTitle = 'Зал'
        PanelHiredJobActive = TavernHiredWaitress
        PanelHiredJobPower = TavernHiredWaitressPower
        PanelHiredJobCost = TavernHiredWaitressCost

    elseif $PanelHiredJob = 'cleaning':
        $PanelHiredJobTitle = 'Уборка'
        PanelHiredJobActive = TavernHiredCleaning
        PanelHiredJobPower = TavernHiredCleaningPower
        PanelHiredJobCost = TavernHiredCleaningCost
    end

    if $PanelHiredJobTitle = '':
        killvar '$PanelHiredJob'
        killvar '$PanelHiredJobTitle'
        exit
    end

    if PanelHiredJobActive = 1:
        $PanelHiredStatus = 'нанят'
        $PanelHiredToggleText = 'Уволить'
    else:
        $PanelHiredStatus = 'нет'
        $PanelHiredToggleText = 'Нанять'
    end

    pl $PanelHiredJobTitle + ': ' + $PanelHiredStatus + ' | сила +' + STR(PanelHiredJobPower) + ' | ' + STR(PanelHiredJobCost) + ' м/день'
    pl '<a href="exec:gs ''PanelHiredStaffToggle'', ''' + $PanelHiredJob + '''">' + $PanelHiredToggleText + '</a>'

    killvar '$PanelHiredJob'
    killvar '$PanelHiredJobTitle'
    killvar '$PanelHiredStatus'
    killvar '$PanelHiredToggleText'
---