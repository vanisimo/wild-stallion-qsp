#OtkrovenMilestoneStub
    $OtkrovenMilestoneGirl = LCASE($ARGS[0])

    cls
    *pl $RealName[$OtkrovenMilestoneGirl]
    *pl ' '
    *p 'This character milestone is reserved for a future scene.'
    *pl ' '

    act 'Back':
        gt 'TavernMain'
    end
---

! Legacy action and NPC talk bridges.
#RegisterGroupSex
    gs 'RegisterGroup', $ARGS[0], ARGS[1]
---

#TalkWithEddie
    gt 'TalkWithNpcStub', 'eddie', 'BeckyShop'
---

#TalkWithClarissa
    gt 'TalkWithNpcStub', 'clarissa', 'WineShop'
---

#TalkWithAlber
    gt 'TalkWithNpcStub', 'alber', 'WineShop'
---

#TalkWithGerhard
    gt 'TalkWithNpcStub', 'gerhard', 'Church'
---

#TalkWithNpcStub
    $NpcTalkKey = LCASE($ARGS[0])
    $NpcTalkReturnLoc = $ARGS[1]

    if $NpcTalkReturnLoc = '' or LOC($NpcTalkReturnLoc) = 0:
        $NpcTalkReturnLoc = 'TavernMain'
    end

    cls
    *pl $RealName[$NpcTalkKey]
    *pl ' '

    if $guytextdesc[$NpcTalkKey] <> '':
        *p $guytextdesc[$NpcTalkKey]
    elseif $girltextdesc[$NpcTalkKey] <> '':
        *p $girltextdesc[$NpcTalkKey]
    else:
        *p 'There is no dedicated dialogue for this character yet.'
    end

    *pl ' '

    act 'Back':
        gt $NpcTalkReturnLoc
    end
---
