! Compatibility aliases for old location names kept by active scenes.
! New code should prefer owner locations directly unless this file documents
! the alias as a public bridge.

! Active knowledge bridges.
#KnowledgeRegisterFact
    gs 'EventKnowledgeRegisterFact', $ARGS[0]
---

#KnowledgeRegisterPlayerKnows
    gs 'EventKnowledgePlayerKnows', $ARGS[0], $ARGS[1]
---

#KnowledgeRegisterRumor
    gs 'EventKnowledgeAddRumor', $ARGS[0], ARGS[1]
---

#KnowledgeRegisterWitness
    gs 'EventKnowledgeAddWitness', $ARGS[0], $ARGS[1]
---

#KnowledgeRegisterSuspect
    gs 'EventKnowledgeNpcSuspects', $ARGS[0], $ARGS[1]
---

#KnowledgeRegisterNpcSuspects
    gs 'EventKnowledgeNpcSuspects', $ARGS[0], $ARGS[1]
---

! Active policy/memory bridges used by current hall and kitchen events.
#HallChoiceMemorySave
    gs 'HallChoiceMemoryRegister', $ARGS[0], $ARGS[2], $ARGS[1]
---

#HallFamilyStateApplyChoice
    gs 'HallFamilyStateApply', $ARGS[0], $ARGS[1], $ARGS[2]
---

#HallFamilyStatePrintLastText
    gs 'HallFamilyStatePrintText', 'after_choice'
---

#HallChoiceConsequencesText
    gs 'HallChoiceConsequenceText', $ARGS[0], $ARGS[1], $ARGS[2]
---

#HallChoiceConsequencePrint
    gs 'HallChoiceConsequencesApply', $ARGS[2], $ARGS[0], $ARGS[1], 'hall'
---

#GirlPolicyResponseEvaluate
    gs 'GirlPolicyResponseCalc', $ARGS[0], $ARGS[1], ARGS[2]
---

#DailyAftermathPrintMorning
    if DailyAftermathPending = 0 or DailyAftermathShownToday = 1:
        exit
    end

    if $DailyAftermathReasonGirl = '' and $LastHallMemoryGirl <> '':
        $DailyAftermathReasonGirl = $LastHallMemoryGirl
        $DailyAftermathReasonEvent = $LastHallMemoryEvent
        $DailyAftermathReasonChoice = $LastHallMemoryChoice
    end

    gs 'DailyAftermathSelect'

    if $DailyAftermathSelected = '':
        exit
    end

    DailyAftermathPending = 0
    DailyAftermathShownToday = 1

    *pl ' '
    gs 'DailyAftermathPrintText', $DailyAftermathSelected
    *pl ' '
---

! Active discussion/family bridges.
#HallRecentTalkCanDiscuss
    gs 'HallRecentTalkCanShow', $ARGS[0]
    HallRecentTalkAvailable = HallRecentTalkCanShow
---

#HallFamilyReactionCanDiscuss
    gs 'HallFamilyReactionCanShow', $ARGS[0]
---

#HallFamilyStateStageName
    if FamilyCorruptionStage <= 0:
        $HallFamilyStateStageName = 'stable'
    elseif FamilyCorruptionStage = 1:
        $HallFamilyStateStageName = 'strained'
    elseif FamilyCorruptionStage = 2:
        $HallFamilyStateStageName = 'shifting'
    elseif FamilyCorruptionStage = 3:
        $HallFamilyStateStageName = 'compromised'
    elseif FamilyCorruptionStage = 4:
        $HallFamilyStateStageName = 'corrupt'
    else:
        $HallFamilyStateStageName = 'broken'
    end
    $Result = $HallFamilyStateStageName
---

! Legacy time bridges.
#AdvanceTimePart
    gs 'NextTime'
---

#NextTimePart
    gs 'NextTime'
---

#NextTime
    time += 1

    if time > 4:
        time = 1
        if LOC('NextDay') = 1:
            gt 'NextDay'
        else:
            day += 1
        end
    end
---

#ProcessNewDay
    if LOC('NextDay') = 1:
        gt 'NextDay'
    else:
        day += 1
        time = 1
    end
---

#TimeControl
    gt 'OLD_TimeControl'
---

#GirlDailyEvent
    $DailyEventGirl = LCASE($ARGS[0])
    if $DailyEventGirl <> '':
        GirlDailyEventSeen[$DailyEventGirl] += 1
    end
    killvar '$DailyEventGirl'
---

