! ================================================
! FILE: modules/debug/debug_port_church_arc.qsps
! MODULE: debug
! Отладка арки Порт → Жоржетта → Церковь (этапы A–H)
! ================================================

#DebugPortChurchArcPanel
    if debug = 0:
        clr
        pl 'DEBUG отключён.'
        exit
    end

    gs 'PanelDebugToolsHeader'

    pl 'DEBUG: ПОРТ → ЖОРЖЕТТА → ЦЕРКОВЬ (A–H)'
    pl 'День ' + STR(day) + ', неделя ' + STR(week) + ', время ' + STR(time)
    pl ' '

    pl '--- Witness / Лизетта ---'
    pl 'PortMeetWitnessed: ' + STR(PortMeetWitnessed)
    pl 'AmandaMetLizette: ' + STR(AmandaMetLizette)
    pl 'LizetteKnown: ' + STR(LizetteKnown)
    pl 'AmandaAtPortShip: ' + STR(AmandaAtPortShip)
    pl ' '

    pl '--- Этап B ---'
    pl 'GeorgetteSeekScheduled: ' + STR(GeorgetteSeekScheduled)
    pl 'GeorgetteSeekStartDay: ' + STR(GeorgetteSeekStartDay)
    pl 'GeorgetteSeekLizetteDone: ' + STR(GeorgetteSeekLizetteDone)
    pl 'GeorgetteKnown: ' + STR(GeorgetteKnown)
    pl 'GeorgettePortSexDone: ' + STR(GeorgettePortSexDone)
    pl '--- Темы talk Жоржетты ---'
    pl 'Bio: ' + STR(GeorgetteTalkBioDone) + ' | Port: ' + STR(GeorgetteTalkPortDone) + ' | Lizette: ' + STR(GeorgetteTalkLizetteDone)
    pl 'Clients: ' + STR(GeorgetteTalkClientsDone) + ' | Sex: ' + STR(GeorgetteTalkSexDone) + ' | Family: ' + STR(GeorgetteTalkFamilyDone) + ' | Children: ' + STR(GeorgetteTalkChildrenDone)
    pl 'Church: ' + STR(GeorgetteTalkChurchDone) + ' | Spy: ' + STR(GeorgetteTalkPriestSpyDone) + ' | LizSpy1: ' + STR(GeorgetteTalkLizetteSpy1Done) + ' | LizPriest: ' + STR(GeorgetteTalkLizettePriestReportDone) + ' | LizSpy2: ' + STR(GeorgetteTalkLizetteSpy2Done) + ' | Eddie: ' + STR(GeorgetteTalkEddieDone)
    pl '--- Темы talk Лизетты ---'
    pl 'Port: ' + STR(LizetteTalkPortDone) + ' | Amanda: ' + STR(LizetteTalkAmandaDone)
    pl '--- Темы talk Ирма ---'
    pl 'Smalltalk: ' + STR(IrmaTalkSmalltalkDone) + ' | Shop: ' + STR(IrmaTalkShopDone)
    pl ' '

    pl '--- Этап C ---'
    pl 'GeorgetteChurchAloneTargetDay: ' + STR(GeorgetteChurchAloneTargetDay)
    pl 'GeorgetteChurchAlone: ' + STR(GeorgetteChurchAlone)
    pl 'GeorgetteFuckInChurch: ' + STR(GeorgetteFuckInChurch)
    pl 'GeorgetteConfessBasic: ' + STR(GeorgetteConfessBasic)
    pl 'GeorgetteConfessLizaSaw: ' + STR(GeorgetteConfessLizaSaw)
    pl 'GeorgettePriestSpySeen: ' + STR(GeorgettePriestSpySeen) + ' | stage: ' + STR(GeorgettePriestSpyStage) + ' / 7'
    pl 'LizetteChurchWithGeorgette: ' + STR(LizetteChurchWithGeorgette)
    pl 'LizaSawSexInChurch: ' + STR(LizaSawSexInChurch)
    pl 'LizettePriestSpyStage: ' + STR(LizettePriestSpyStage)
    pl 'LizettePriestSpySeen: ' + STR(LizettePriestSpySeen)
    pl 'LizetteSexUnlocked: ' + STR(LizetteSexUnlocked)
    pl 'ChurchSpyBasicUnlocked: ' + STR(ChurchSpyBasicUnlocked)
    pl 'ChurchSpyWindowHint: ' + STR(ChurchSpyWindowHint)
    pl 'ChurchSpyWindowUpgrade: ' + STR(ChurchSpyWindowUpgrade)
    pl 'ChurchSpyWindowGearGossipHeard: ' + STR(ChurchSpyWindowGearGossipHeard)
    pl 'ChurchSpyWindowMechanismFound: ' + STR(ChurchSpyWindowMechanismFound)
    pl 'ChurchSundayNoonVisitCount: ' + STR(ChurchSundayNoonVisitCount)
    pl 'ChurchConfessionDoneDay: ' + STR(ChurchConfessionDoneDay)
    pl 'ChurchServiceRumorCount: ' + STR(ChurchServiceRumorCount) + ' (day ' + STR(ChurchServiceRumorDay) + ')'
    pl 'LizetteProstPort: ' + STR(LizetteProstPort)
    pl 'PortAlleySpySeenCount: ' + STR(PortAlleySpySeenCount)
    pl 'Friends[georgett]: ' + STR(Friends['georgett'])
    pl 'HadSex[georgett]: ' + STR(HadSex['georgett'])
    pl ' '

    pl '--- Быстрые пресеты ---'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetShipWednesday''">Среда: корабль, до witness (A)</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetAfterWitness''">После witness (B ждёт next_day)</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetSeekToday''">B сегодня: ивент в порту</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetAfterB''">После B: ночной порт</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetSundayC''">Воскресенье C1: служба + Жоржетта</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetAfterC''">После C: секс в соборе был</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetSundayD''">Воскресенье D: полдень, исповедь</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetSundayE''">Воскресенье E: spy Жоржетта</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetAfterE''">После E: ночь в порту + talk</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetSundayF''">Воскресенье F: Лизетта на службе</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcPresetSundayH''">После G2: ночной порт H</a>'
    pl ' '

    pl '--- Переходы ---'
    pl '<a href="exec:gt ''Port''">Порт</a> | <a href="exec:gt ''Church''">Церковь</a> | <a href="exec:gt ''PortCapitalShipMenu'',''Port''">Корабль</a>'
    pl '<a href="exec:gt ''ChurchSundayService''">Служба (если вс/утро)</a>'
    pl '<a href="exec:gt ''ChurchSundayNoon''">Полдень (если вс/полдень)</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcGiveWindowHint''">+ hint окна (как у лавки Бекки)</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcGiveWindowMechanism''">+ механизм найден (окно приоткрыто)</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcUnlockGeorgetteTalks''">+ все темы Жоржетты</a>'
    pl '<a href="exec:gs ''DebugPortChurchArcUnlockLizetteTalks''">+ все темы Лизетты</a>'
    pl ' '

    gs 'PanelDebugToolsBack'
---

#DebugPortChurchArcPresetShipWednesday
    week = 3
    time = 2
    PortMeetWitnessed = 0
    AmandaMetLizette = 0
    LizetteKnown = 0
    GeorgetteKnown = 0
    GeorgetteSeekScheduled = 0
    GeorgetteSeekStartDay = 0
    GeorgetteSeekLizetteDone = 0
    GeorgettePortSexDone = 0
    GeorgetteChurchAlone = 0
