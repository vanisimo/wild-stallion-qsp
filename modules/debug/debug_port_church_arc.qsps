    GeorgetteTalkLizetteDone = 1
    GeorgetteTalkChurchDone = 0
    GeorgetteTalkPriestSpyDone = 0
    GeorgetteTalkEddieDone = 0

    if $DebugGeorgetteRelStage = 'b':
        Friends['georgett'] = 14
        otkroven['georgett'] = 12
        GeorgettePortSexDone = 0
        GeorgetteTalkClientsDone = 0
        HadSex['georgett'] = 0
        IntimStage['georgett'] = 0
    elseif $DebugGeorgetteRelStage = 'c':
        Friends['georgett'] = 22
        otkroven['georgett'] = 18
        GeorgettePortSexDone = 1
        GeorgetteTalkClientsDone = 1
        HadSex['georgett'] = 1
        IntimStage['georgett'] = 5
        GeorgetteFuckInChurch = 0
        GeorgettePriestSpySeen = 0
        GeorgettePriestSpyStage = 0
    elseif $DebugGeorgetteRelStage = 'c2':
        Friends['georgett'] = 24
        otkroven['georgett'] = 22
        GeorgettePortSexDone = 1
        GeorgetteTalkClientsDone = 1
        HadSex['georgett'] = 1
        IntimStage['georgett'] = 5
        GeorgetteFuckInChurch = 1
        GeorgetteConfessBasic = 0
        GeorgettePriestSpySeen = 0
        GeorgettePriestSpyStage = 0
    elseif $DebugGeorgetteRelStage = 'd':
        Friends['georgett'] = 24
        otkroven['georgett'] = 22
        GeorgettePortSexDone = 1
        GeorgetteTalkClientsDone = 1
        HadSex['georgett'] = 1
        IntimStage['georgett'] = 5
        GeorgetteFuckInChurch = 1
        GeorgetteConfessBasic = 0
        GeorgettePriestSpySeen = 0
        GeorgettePriestSpyStage = 0
    elseif $DebugGeorgetteRelStage = 'e':
        Friends['georgett'] = 26
        otkroven['georgett'] = 26
        GeorgettePortSexDone = 1
        GeorgetteTalkClientsDone = 1
        HadSex['georgett'] = 1
        IntimStage['georgett'] = 5
        GeorgetteFuckInChurch = 1
        GeorgetteConfessBasic = 1
        GeorgettePriestSpySeen = 1
        GeorgettePriestSpyStage = 1
    elseif $DebugGeorgetteRelStage = 'f':
        Friends['georgett'] = 28
        otkroven['georgett'] = 28
        GeorgettePortSexDone = 1
        GeorgetteTalkClientsDone = 1
        GeorgetteTalkPriestSpyDone = 1
        HadSex['georgett'] = 1
        IntimStage['georgett'] = 5
        GeorgetteFuckInChurch = 1
        GeorgetteConfessBasic = 1
        GeorgettePriestSpySeen = 1
        GeorgettePriestSpyStage = 1
    elseif $DebugGeorgetteRelStage = 'h':
        Friends['georgett'] = 30
        otkroven['georgett'] = 30
        GeorgettePortSexDone = 1
        GeorgetteTalkClientsDone = 1
        GeorgetteTalkChurchDone = 1
        GeorgetteTalkPriestSpyDone = 1
        HadSex['georgett'] = 2
        IntimStage['georgett'] = 5
        GeorgetteFuckInChurch = 1
        GeorgetteConfessBasic = 1
        GeorgettePriestSpySeen = 1
        GeorgettePriestSpyStage = 7
    end

    gs 'ClampGirlSocialStats', 'georgett'
    killvar '$DebugGeorgetteRelStage'
